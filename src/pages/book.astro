---
import Page from '../layouts/Page.astro';
---

<Page
  title="Book Your Event — All Star Party World & The 305 Club"
  description="Reserve your date at All Star Party World or The 305 Club. Complete the form and our event team will reach out within 24 hours with availability, pricing, and a custom proposal."
>

  <div class="book-page">
    <div class="book-inner">

      <!-- Header -->
      <header class="book-header" aria-label="Booking page header">
        <p class="page-eyebrow">Reserve Your Date</p>
        <h1 class="page-title">Book Your Event</h1>
        <p class="page-sub">Complete the form below and our event team will reach out within 24 hours with availability, pricing, and a custom proposal.</p>
      </header>

      <div class="book-grid">

        <!-- Form -->
        <div>
          <form
            id="booking-form"
            class="form-card"
            aria-label="Event booking form"
            novalidate
          >
            <!-- Venue Selector -->
            <fieldset class="venue-selector" aria-labelledby="venue-legend">
              <legend id="venue-legend" class="form-section-title">Select Venue</legend>
              <div class="venue-options">
                <label class="venue-option" aria-label="All Star Party World — Kids ages 4–12">
                  <input type="radio" name="venue" value="all-star-party-world" required />
                  <div class="venue-option-content">
                    <span class="venue-dot allstar" aria-hidden="true"></span>
                    <div>
                      <strong>All Star Party World</strong>
                      <span>Kids ages 4–12</span>
                    </div>
                  </div>
                </label>
                <label class="venue-option" aria-label="The 305 Club — Teens and adults">
                  <input type="radio" name="venue" value="305-club" />
                  <div class="venue-option-content">
                    <span class="venue-dot club" aria-hidden="true"></span>
                    <div>
                      <strong>The 305 Club</strong>
                      <span>Teens &amp; adults</span>
                    </div>
                  </div>
                </label>
                <label class="venue-option" aria-label="Both venues — Coordinate same-day event">
                  <input type="radio" name="venue" value="both" />
                  <div class="venue-option-content">
                    <span class="venue-dot both" aria-hidden="true"></span>
                    <div>
                      <strong>Both Venues</strong>
                      <span>Same-day coordination</span>
                    </div>
                  </div>
                </label>
              </div>
            </fieldset>

            <div class="form-divider" aria-hidden="true"></div>

            <!-- Contact Info -->
            <fieldset class="form-section" aria-labelledby="contact-legend">
              <legend id="contact-legend" class="form-section-title">Contact Info</legend>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="first-name">First Name <span class="required" aria-label="required">*</span></label>
                  <input type="text" id="first-name" name="firstName" class="form-input" placeholder="Maria" autocomplete="given-name" required aria-required="true" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="last-name">Last Name <span class="required" aria-label="required">*</span></label>
                  <input type="text" id="last-name" name="lastName" class="form-input" placeholder="Rodriguez" autocomplete="family-name" required aria-required="true" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="cell-phone">Cell Phone <span class="required" aria-label="required">*</span></label>
                  <input type="tel" id="cell-phone" name="cellPhone" class="form-input" placeholder="(305) 000-0000" autocomplete="tel" required aria-required="true" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="secondary-phone">Secondary Phone</label>
                  <input type="tel" id="secondary-phone" name="secondaryPhone" class="form-input" placeholder="(786) 000-0000" autocomplete="tel" />
                </div>
              </div>
              <div class="form-group" style="margin-bottom:0.85rem;">
                <label class="form-label" id="text-opt-label">OK to text you?</label>
                <label class="checkbox-label" aria-labelledby="text-opt-label">
                  <input type="checkbox" name="okToText" value="yes" checked />
                  <span class="checkbox-custom" aria-hidden="true"></span>
                  Yes, text me
                </label>
                <p class="form-hint">We only contact you regarding your inquiry. Reply STOP to opt out.</p>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="best-time">Best Time to Call</label>
                  <input type="text" id="best-time" name="bestTimeToCall" class="form-input" placeholder="e.g. After 4pm weekdays" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="email">Email <span class="required" aria-label="required">*</span></label>
                  <input type="email" id="email" name="email" class="form-input" placeholder="you@email.com" autocomplete="email" required aria-required="true" />
                </div>
              </div>
            </fieldset>

            <div class="form-divider" aria-hidden="true"></div>

            <!-- Event Details -->
            <fieldset class="form-section" aria-labelledby="event-legend">
              <legend id="event-legend" class="form-section-title">Event Details</legend>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="preferred-date">Preferred Date <span class="required" aria-label="required">*</span></label>
                  <input type="date" id="preferred-date" name="preferredDate" class="form-input" required aria-required="true" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="alternate-date">Alternate Date</label>
                  <input type="date" id="alternate-date" name="alternateDate" class="form-input" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="start-time">Party Start Time</label>
                  <input type="text" id="start-time" name="startTime" class="form-input" placeholder="e.g. 2:00 PM" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="num-kids">Number of Kids</label>
                  <input type="number" id="num-kids" name="numKids" class="form-input" placeholder="0" min="0" />
                </div>
              </div>
              <div class="form-group" style="margin-bottom:0.85rem;">
                <label class="form-label" id="party-length-label">Party Length <span class="required" aria-label="required">*</span></label>
                <div class="radio-group" role="group" aria-labelledby="party-length-label">
                  <label class="radio-label">
                    <input type="radio" name="partyLength" value="2hrs" required />
                    <span class="radio-custom" aria-hidden="true"></span>
                    2 hours
                  </label>
                  <label class="radio-label">
                    <input type="radio" name="partyLength" value="3hrs" />
                    <span class="radio-custom" aria-hidden="true"></span>
                    3 hours
                  </label>
                  <label class="radio-label">
                    <input type="radio" name="partyLength" value="4hrs+" />
                    <span class="radio-custom" aria-hidden="true"></span>
                    4 hours+
                  </label>
                  <label class="radio-label">
                    <input type="radio" name="partyLength" value="not-sure" />
                    <span class="radio-custom" aria-hidden="true"></span>
                    Not sure yet
                  </label>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="num-adults">Number of Adults</label>
                  <input type="number" id="num-adults" name="numAdults" class="form-input" placeholder="0" min="0" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="birthday-age">Birthday Person's Age</label>
                  <input type="text" id="birthday-age" name="birthdayAge" class="form-input" placeholder="e.g. 7" />
                </div>
              </div>
              <div class="form-group" style="margin-bottom:0.85rem;">
                <label class="form-label" for="celebrating">Who Are We Celebrating?</label>
                <input type="text" id="celebrating" name="celebrating" class="form-input" placeholder="e.g. Sofia's 7th Birthday" />
              </div>
            </fieldset>

            <div class="form-divider" aria-hidden="true"></div>

            <!-- Party Preferences -->
            <fieldset class="form-section" aria-labelledby="prefs-legend">
              <legend id="prefs-legend" class="form-section-title">Tell Us More</legend>

              <div class="form-group" style="margin-bottom:0.85rem;">
                <label class="form-label" for="party-description">Party Description</label>
                <textarea
                  id="party-description"
                  name="partyDescription"
                  class="form-textarea"
                  placeholder="Tell us what kind of party you're interested in. Do you need catering? A DJ? A specific activity or experience? Any special requests?"
                ></textarea>
              </div>
              <div class="form-group" style="margin-bottom:0.85rem;">
                <label class="form-label" for="hear-about-us">How Did You Hear About Us?</label>
                <select id="hear-about-us" name="hearAboutUs" class="form-select">
                  <option value="">Select one…</option>
                  <option value="google">Google</option>
                  <option value="instagram">Instagram</option>
                  <option value="facebook">Facebook</option>
                  <option value="tiktok">TikTok</option>
                  <option value="youtube">YouTube</option>
                  <option value="referral">Friend / Family Referral</option>
                  <option value="drove-by">Drove By</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </fieldset>

            <!-- Status messages -->
            <div id="form-error" class="form-status error" role="alert" aria-live="assertive" hidden>
              <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
              <span id="form-error-msg">Please fill in all required fields.</span>
            </div>
            <div id="form-success" class="form-status success" role="status" aria-live="polite" hidden>
              <i class="fas fa-check-circle" aria-hidden="true"></i>
              <span>Your request was sent! We'll be in touch within 24 hours.</span>
            </div>

            <button type="submit" class="form-submit" id="form-submit-btn">
              <span id="submit-label">Send My Booking Request</span>
              <span id="submit-loading" hidden aria-hidden="true">
                <i class="fas fa-spinner fa-spin"></i> Sending…
              </span>
            </button>
            <p class="form-footer-note">No payment required now. We'll send a proposal first.</p>
          </form>
        </div>

        <!-- Sidebar -->
        <aside aria-label="Contact information and booking tips">
          <div class="info-card">
            <div class="info-title">Contact &amp; Location</div>
            <div class="info-item">
              <div class="info-icon" aria-hidden="true"><i class="fa-solid fa-phone"></i></div>
              <div>
                <div class="info-label">Phone</div>
                <div class="info-value"><a href="tel:+17864710100">786-471-0100</a></div>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon" aria-hidden="true"><i class="fa-solid fa-location-dot"></i></div>
              <div>
                <div class="info-label">Address</div>
                <div class="info-value">
                  8770 SW 131st Street<br />
                  Miami, Florida 33176<br />
                  <span style="font-size:0.78rem;color:rgba(255,255,255,0.4);">Next to The Falls Shopping Center</span>
                </div>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon" aria-hidden="true"><i class="fa-solid fa-clock"></i></div>
              <div>
                <div class="info-label">Response Time</div>
                <div class="info-value">Within 24 hours</div>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon" aria-hidden="true"><i class="fa-solid fa-calendar-check"></i></div>
              <div>
                <div class="info-label">Booking Window</div>
                <div class="info-value">Book 3–6 months ahead for best date availability</div>
              </div>
            </div>
          </div>

          <div class="tip-box">
            <div class="tip-label">Pro Tip</div>
            <p class="tip-text">Popular dates (Friday nights, Saturday afternoons) fill up fast — especially June through August and holidays. Submit early and include your alternate date.</p>
          </div>

          <div class="venues-box">
            <div class="tip-label">Two Venues Available</div>
            <div class="venues-list">
              <a href="/all-star-party-world" class="venue-link">
                <span class="venue-dot allstar" aria-hidden="true"></span>
                <div>
                  <strong>All Star Party World</strong>
                  <span>6,000 sq ft · Kids ages 4–12</span>
                </div>
                <i class="fas fa-arrow-right" aria-hidden="true"></i>
              </a>
              <a href="/305-club" class="venue-link">
                <span class="venue-dot club" aria-hidden="true"></span>
                <div>
                  <strong>The 305 Club</strong>
                  <span>10,000 sq ft · Teens &amp; adults</span>
                </div>
                <i class="fas fa-arrow-right" aria-hidden="true"></i>
              </a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </div>

</Page>

<style>
  /* ── Layout ── */
  .book-page { background: #0e0f14; padding: 4rem 2rem 6rem; }
  .book-inner { max-width: 1100px; margin: 0 auto; }

  /* ── Header ── */
  .page-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: #7fb3ff; margin-bottom: 0.75rem; display: block;
  }
  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.95; margin-bottom: 0.75rem;
  }
  .page-sub {
    font-size: 0.95rem; color: rgba(255,255,255,0.55);
    line-height: 1.7; margin-bottom: 2.5rem; max-width: 560px;
  }

  .book-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    align-items: start;
  }
  .book-grid aside {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  /* ── Form Card ── */
  .form-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 2px solid #3B7DEB;
    border-radius: 16px;
    padding: 2.5rem;
  }

  .form-section-title {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1.25rem;
    display: block;
  }
  .form-divider {
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin: 1.5rem 0;
  }
  .form-section { border: none; padding: 0; margin: 0; }
  .venue-selector { border: none; padding: 0; margin: 0; }

  /* ── Venue Options ── */
  .venue-options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .venue-option {
    cursor: pointer;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .venue-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .venue-option:has(input:checked) {
    border-color: #3B7DEB;
    background: rgba(59,125,235,0.08);
  }
  .venue-option:focus-within { outline: 2px solid #3B7DEB; outline-offset: 2px; border-radius: 10px; }
  .venue-option-content {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .venue-option-content div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .venue-option-content strong {
    font-size: 0.82rem;
    font-weight: 600;
    color: #fff;
    display: block;
  }
  .venue-option-content span {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.45);
  }
  .venue-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .venue-dot.allstar { background: #F5C518; box-shadow: 0 0 6px rgba(245,197,24,0.5); }
  .venue-dot.club { background: #3B7DEB; box-shadow: 0 0 6px rgba(59,125,235,0.5); }
  .venue-dot.both {
    background: linear-gradient(135deg, #F5C518 50%, #3B7DEB 50%);
    box-shadow: 0 0 6px rgba(59,125,235,0.3);
  }

  /* ── Form Fields ── */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
    margin-bottom: 0.85rem;
  }
  .form-group { display: flex; flex-direction: column; gap: 0.3rem; }

  .form-label {
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }
  .required { color: #E8357A; }

  .form-input, .form-select, .form-textarea {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.65rem 0.9rem;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    outline: none;
    width: 100%;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .form-input::placeholder, .form-textarea::placeholder { color: rgba(255,255,255,0.2); }
  .form-input:focus, .form-select:focus, .form-textarea:focus {
    border-color: #3B7DEB;
    box-shadow: 0 0 0 3px rgba(59,125,235,0.15);
  }
  .form-select { appearance: none; cursor: pointer; }
  .form-select option { background: #222734; }
  .form-textarea { resize: vertical; min-height: 110px; }
  .form-hint {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.5;
    margin-top: 0.35rem;
  }
  .form-optional {
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.06em;
    margin-left: 0.4rem;
  }
  .form-link {
    color: #F5C518;
    text-decoration: none;
    font-size: 0.68rem;
  }
  .form-link:hover { text-decoration: underline; }

  /* ── Balloon Package Selector ── */
  .balloon-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    margin-top: 0.65rem;
    align-items: stretch;
  }
  .balloon-option {
    display: flex;
    width: 100%;
    cursor: pointer;
  }
  .balloon-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .balloon-option-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.03);
    transition: border-color 0.2s ease, background 0.2s ease;
    user-select: none;
    width: 100%;
    min-height: 100px;
  }
  .balloon-option:hover .balloon-option-content {
    border-color: rgba(245,197,24,0.35);
    background: rgba(245,197,24,0.04);
  }
  .balloon-option input:checked + .balloon-option-content {
    border-color: #F5C518;
    background: rgba(245,197,24,0.08);
    box-shadow: 0 0 0 1px rgba(245,197,24,0.3);
  }
  .balloon-option input:focus-visible + .balloon-option-content {
    outline: 2px solid #3B7DEB;
    outline-offset: 2px;
  }
  .balloon-option-name {
    font-family: 'Oswald', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #fff;
  }
  .balloon-option-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    color: #F5C518;
    line-height: 1;
  }
  .balloon-option-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.4;
  }
  .balloon-note {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.25);
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .balloon-options { grid-template-columns: 1fr; }
  }

  /* ── Checkbox ── */
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.75);
    cursor: pointer;
    margin-top: 0.3rem;
  }
  .checkbox-label input[type="checkbox"] { position: absolute; opacity: 0; pointer-events: none; }
  .checkbox-custom {
    width: 16px; height: 16px;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    flex-shrink: 0;
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .checkbox-label:has(input:checked) .checkbox-custom {
    background: #3B7DEB;
    border-color: #3B7DEB;
  }
  .checkbox-label:has(input:checked) .checkbox-custom::after {
    content: '';
    position: absolute;
    left: 4px; top: 1px;
    width: 5px; height: 9px;
    border: 2px solid #fff;
    border-top: none; border-left: none;
    transform: rotate(45deg);
  }

  /* ── Radio Group ── */
  .radio-group {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.4rem;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
  }
  .radio-label input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
  .radio-custom {
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.05);
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.2s ease;
  }
  .radio-label:has(input:checked) .radio-custom {
    border-color: #3B7DEB;
    background: rgba(59,125,235,0.15);
  }
  .radio-label:has(input:checked) .radio-custom::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #3B7DEB;
  }

  /* ── Status ── */
  .form-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .form-status.error { background: rgba(232,53,122,0.1); border: 1px solid rgba(232,53,122,0.3); color: #ff8ab0; }
  .form-status.success { background: rgba(59,235,130,0.1); border: 1px solid rgba(59,235,130,0.3); color: #7fffc0; }
  .form-status[hidden] { display: none; }

  /* ── Submit ── */
  .form-submit {
    width: 100%;
    background: #3B7DEB;
    color: #fff;
