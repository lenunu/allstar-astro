---
import Page from '../layouts/Page.astro';
---

<Page
  title="FAQ — All Star Party World & The 305 Club"
  description="Answers to the most common questions about booking, packages, food, deposits, waivers, and more at All Star Party World and The 305 Club."
>

  <!-- ── HERO ── -->
  <section class="faq-hero">
    <div class="faq-hero-inner">
      <span class="eyebrow">Got Questions?</span>
      <h1>Frequently Asked <span class="accent">Questions</span></h1>
      <p class="hero-sub">Everything you need to know before booking. Can't find your answer? <a href="tel:+17864710100" class="inline-link">Call us at 786-471-0100</a>.</p>
    </div>
  </section>

  <div class="faq-page">

    <!-- ── BOOKING & RESERVATIONS ── -->
    <section class="faq-section" aria-labelledby="cat-booking">
      <div class="faq-section-inner">
        <div class="cat-label">
          <span class="cat-icon" aria-hidden="true"><i class="fa-regular fa-calendar-check"></i></span>
          <h2 id="cat-booking">Booking & Reservations</h2>
        </div>
        <div class="faq-list" role="list">

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-b1">
              <span>How do I reserve my event?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-b1" role="region">
              <div class="faq-answer-inner">Give us a call at <a href="tel:+17864710100" class="inline-link">786-471-0100</a> or fill out our <a href="/book" class="inline-link">online booking form</a>. An event coordinator will reach out to confirm details, walk you through your options, and lock in your date.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-b2">
              <span>Is a deposit required?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-b2" role="region">
              <div class="faq-answer-inner">Yes — a <strong>$500 non-refundable deposit</strong> is required to secure your date and time. This amount is applied directly to your final party invoice.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-b3">
              <span>How far in advance should I book?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-b3" role="region">
              <div class="faq-answer-inner">The sooner the better — Friday and Saturday dates book out months in advance. For large events like quinceañeras and sweet 16s, we recommend reaching out <strong>at least 3–6 months ahead</strong>. For smaller gatherings, 4–6 weeks is usually enough.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-b4">
              <span>Can we stay longer than our scheduled time slot?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-b4" role="region">
              <div class="faq-answer-inner">Additional time can be purchased based on availability. Let your event coordinator know when booking and we'll work it into your proposal.</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="section-divider" aria-hidden="true"></div>

    <!-- ── ALL STAR PARTY WORLD ── -->
    <section class="faq-section" aria-labelledby="cat-allstar">
      <div class="faq-section-inner">
        <div class="cat-label">
          <span class="cat-icon yellow" aria-hidden="true"><i class="fa-solid fa-star"></i></span>
          <h2 id="cat-allstar">All Star Party World <span class="venue-tag yellow-tag">Kids Ages 4–12</span></h2>
        </div>
        <div class="faq-list" role="list">

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as1">
              <span>Who is All Star Party World for?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as1" role="region">
              <div class="faq-answer-inner">All Star Party World is designed for kids ages 4–12. Our Ultimate Package was built for every age group — boys and girls alike. From birthday parties and glow parties to school events and field trips, if kids are involved, we've got it covered.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as2">
              <span>Is the whole venue just for my party?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as2" role="region">
              <div class="faq-answer-inner">Yes — we only host <strong>one party at a time</strong>. When you book All Star Party World, you get exclusive access to the entire 6,000 sq ft facility. No strangers, no overlap, no sharing.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as3">
              <span>What's included in the Ultimate Package?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as3" role="region">
              <div class="faq-answer-inner">The Ultimate Package includes: 2 hours of exclusive venue access plus 30 minutes early setup, bounce house, 2,500 sq ft blacklight glow room with dodgeball / freeze tag / basketball / scooter soccer, ping-pong, Connect Four, pizza and drinks for up to 25 kids, 4 party specialists, cake table, food and gift tables, and 6 tables with bench seating.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as4">
              <span>What are Party Extras and how do I add them?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as4" role="region">
              <div class="faq-answer-inner">Party Extras are add-ons that upgrade your event — Laser Tag, Nerf Wars, Karaoke, 360 Photo Booth, Cotton Candy, Snow Cones, and more. Just mention which ones you want when booking and we'll build them into your custom proposal.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as5">
              <span>Are all guests required to wear socks?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as5" role="region">
              <div class="faq-answer-inner">Yes — all guests who participate in the inflatables must wear socks for safety. If guests arrive without socks, they are available for purchase at the venue.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as6">
              <span>What time should guests arrive?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as6" role="region">
              <div class="faq-answer-inner">Guests will not be allowed inside until the scheduled party time or 5 minutes before, once setup is complete. Please plan accordingly to make a great entrance!</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-as7">
              <span>Do you have a teen and adult venue nearby?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-as7" role="region">
              <div class="faq-answer-inner">Yes — <a href="/305-club" class="inline-link">The 305 Club</a> is our sister venue for teens and adults, located at the same address. Perfect for multi-generational events: kids party at All Star while the adults celebrate at The 305 Club. One call handles both.</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="section-divider" aria-hidden="true"></div>

    <!-- ── THE 305 CLUB ── -->
    <section class="faq-section" aria-labelledby="cat-305">
      <div class="faq-section-inner">
        <div class="cat-label">
          <span class="cat-icon blue" aria-hidden="true"><i class="fa-solid fa-music"></i></span>
          <h2 id="cat-305">The 305 Club <span class="venue-tag blue-tag">Teens & Adults</span></h2>
        </div>
        <div class="faq-list" role="list">

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-305-1">
              <span>Who is The 305 Club for?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-305-1" role="region">
              <div class="faq-answer-inner">Teens and adults — we specialize in making anyone feel like a superstar. From quinceañeras and sweet 16s to corporate events and holiday parties, if you want a night your guests won't stop talking about, this is your venue.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-305-2">
              <span>What's included in the venue rental?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-305-2" role="region">
              <div class="faq-answer-inner">Your rental includes the full 10,000 sq ft space, lighted furniture, our graffiti wall, GOBO and TV wall displays, professional DJ equipment, event staff, setup, and cleanup. It's a full-production venue — not just a room.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-305-3">
              <span>Can you host unique events like pop-up museums or live shows?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-305-3" role="region">
              <div class="faq-answer-inner">Absolutely. Beyond private parties, we've hosted pop-up museums, live musical events, and acting playhouse productions. Our space is flexible and our team has the experience to make unconventional events work beautifully.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-305-4">
              <span>Do you have a kids venue nearby?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-305-4" role="region">
              <div class="faq-answer-inner">Yes — <a href="/all-star-party-world" class="inline-link">All Star Party World</a> is our sister venue for kids ages 4–12, located at the same address. Perfect for multi-generational events: the kids celebrate at All Star while the older crowd enjoys The 305 Club. One call, two venues.</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="section-divider" aria-hidden="true"></div>

    <!-- ── FOOD & DRINKS ── -->
    <section class="faq-section" aria-labelledby="cat-food">
      <div class="faq-section-inner">
        <div class="cat-label">
          <span class="cat-icon pink" aria-hidden="true"><i class="fa-solid fa-utensils"></i></span>
          <h2 id="cat-food">Food & Drinks</h2>
        </div>
        <div class="faq-list" role="list">

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-f1">
              <span>Can I bring my own food?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-f1" role="region">
              <div class="faq-answer-inner">Yes — outside food and beverages are welcome at no extra cost. Most All Star packages include pizza and drinks for up to 25 kids. We also offer a <a href="/catering" class="inline-link">full catering menu</a> if you'd prefer to let us handle it.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-f2">
              <span>Can I bring a birthday cake?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-f2" role="region">
              <div class="faq-answer-inner">Absolutely — you're welcome to bring your own birthday cake or any desserts you'd like.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-f3">
              <span>Can I bring adult beverages?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-f3" role="region">
              <div class="faq-answer-inner">Yes, adult beverages are permitted, but you must provide event liability insurance that includes <strong>host liquor liability</strong> naming the facility as an additional insured. Contact your coordinator for details.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-f4">
              <span>Do you offer catering?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-f4" role="region">
              <div class="faq-answer-inner">Yes — we have a full catering menu with salads, mains, sides, desserts, and more. Our team works with you to customize food and beverage options for your event. <a href="/catering" class="inline-link">Browse the menu here</a>.</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="section-divider" aria-hidden="true"></div>

    <!-- ── DECORATIONS & VENDORS ── -->
    <section class="faq-section" aria-labelledby="cat-decor">
      <div class="faq-section-inner">
        <div class="cat-label">
          <span class="cat-icon pink" aria-hidden="true"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
          <h2 id="cat-decor">Decorations & Vendors</h2>
        </div>
        <div class="faq-list" role="list">

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-d1">
              <span>Are decorations and paper products included?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-d1" role="region">
              <div class="faq-answer-inner">Decorations and paper products are not included. You're welcome to bring your own table covers and decorations — just nothing taped to the walls. <a href="/balloon-packages" class="inline-link">Balloon packages</a> are available as an add-on.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-d2">
              <span>Are outside vendors allowed?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-d2" role="region">
              <div class="faq-answer-inner">Yes — outside vendors are generally permitted, but must be discussed and approved in advance. All vendors are required to carry valid liability insurance naming the facility as an additional insured.</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="section-divider" aria-hidden="true"></div>

    <!-- ── SAFETY & WAIVERS ── -->
    <section class="faq-section" aria-labelledby="cat-safety">
      <div class="faq-section-inner">
        <div class="cat-label">
          <span class="cat-icon yellow" aria-hidden="true"><i class="fa-solid fa-shield-halved"></i></span>
          <h2 id="cat-safety">Safety & Waivers</h2>
        </div>
        <div class="faq-list" role="list">

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-s1">
              <span>Who needs to sign a waiver?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-s1" role="region">
              <div class="faq-answer-inner">All guests who participate in activities at All Star Party World must complete and sign a waiver. Parents or legal guardians must sign on behalf of minors. Waivers must be completed in person upon arrival, or you can <a href="/waiver" class="inline-link">complete yours online in advance</a>.</div>
            </div>
          </div>

          <div class="faq-item" role="listitem">
            <button class="faq-question" aria-expanded="false" aria-controls="faq-s2">
              <span>What safety rules does the venue enforce?</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id="faq-s2" role="region">
              <div class="faq-answer-inner">Our staff reviews all facility rules with guests upon arrival and remain present in play areas throughout the event to ensure compliance. Guests wearing casts, slings, or motion-limiting devices may be restricted from participating in certain activities for their safety.</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── STILL HAVE QUESTIONS ── -->
    <section class="faq-cta">
      <div class="faq-cta-inner">
        <h2>Still have questions?</h2>
        <p>Our team is happy to walk you through everything. Give us a call or fill out the booking form and we'll get back to you fast.</p>
        <div class="faq-cta-actions">
          <a href="/book" class="btn-primary"><i class="fa-regular fa-calendar" aria-hidden="true"></i> Book Your Event</a>
          <a href="tel:+17864710100" class="btn-outline"><i class="fa-solid fa-phone" aria-hidden="true"></i> 786-471-0100</a>
        </div>
      </div>
    </section>

  </div>

</Page>

<style>
  /* ── HERO ── */
  .faq-hero {
    background: linear-gradient(180deg, #14161e 0%, #0e0f14 100%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 5rem 2rem 4rem;
    text-align: center;
  }
  .faq-hero-inner { max-width: 700px; margin: 0 auto; }
  .eyebrow {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #F5C518;
    margin-bottom: 1rem;
  }
  .faq-hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: #fff;
    margin-bottom: 1rem;
  }
  .accent { color: #F5C518; }
  .hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  /* ── PAGE WRAPPER ── */
  .faq-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── SECTION ── */
  .faq-section { padding: 3.5rem 0; }
  .faq-section-inner {}

  .cat-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .cat-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }
  .cat-icon.yellow { background: rgba(245,197,24,0.12); color: #F5C518; }
  .cat-icon.blue   { background: rgba(59,125,235,0.12); color: #3B7DEB; }
  .cat-icon.pink   { background: rgba(232,53,122,0.12); color: #E8357A; }

  .cat-label h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .venue-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.2em 0.6em;
    border-radius: 4px;
  }
  .yellow-tag { background: rgba(245,197,24,0.15); color: #F5C518; }
  .blue-tag   { background: rgba(59,125,235,0.15); color: #7fb3ff; }

  /* ── FAQ ITEMS ── */
  .faq-list { display: flex; flex-direction: column; gap: 0; }

  .faq-item {
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .faq-item:first-child { border-top: 1px solid rgba(255,255,255,0.07); }

  .faq-question {
    width: 100%;
    background: none;
    border: none;
    color: #fff;
    text-align: left;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    transition: color 0.2s ease;
  }
  .faq-question:hover { color: #F5C518; }
  .faq-question[aria-expanded="true"] { color: #F5C518; }

  .faq-icon {
    font-size: 1.3rem;
    font-weight: 300;
    line-height: 1;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
    transition: transform 0.25s ease, color 0.2s ease;
  }
  .faq-question[aria-expanded="true"] .faq-icon {
    transform: rotate(45deg);
    color: #F5C518;
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .faq-answer.open { grid-template-rows: 1fr; }

  .faq-answer-inner {
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.6);
    padding-bottom: 1.25rem;
  }

  .inline-link {
    color: #F5C518;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(245,197,24,0.4);
    transition: text-decoration-color 0.2s ease;
  }
  .inline-link:hover { text-decoration-color: #F5C518; }

  /* ── DIVIDER ── */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08) 30%, rgba(255,255,255,0.08) 70%, transparent);
  }

  /* ── CTA ── */
  .faq-cta {
    background: #14161e;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    margin: 3.5rem 0 5rem;
    padding: 3rem 2rem;
    text-align: center;
  }
  .faq-cta h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.04em;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .faq-cta p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 2rem;
  }
  .faq-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #3B7DEB;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.75rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 0 20px rgba(59,125,235,0.35);
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(59,125,235,0.5);
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.75);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.75rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .btn-outline:hover { border-color: rgba(255,255,255,0.5); color: #fff; }
</style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;

      // close all others
      document.querySelectorAll('.faq-question[aria-expanded="true"]').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const otherId = other.getAttribute('aria-controls')!;
          document.getElementById(otherId)?.classList.remove('open');
        }
      });

      btn.setAttribute('aria-expanded', String(!isOpen));
      answer.classList.toggle('open', !isOpen);
    });
  });
</script>
