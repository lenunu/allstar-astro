    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 0.8rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .side-cart-close:hover { color: #fff; border-color: rgba(255,255,255,0.3); }
  .side-cart-close:focus-visible { outline: 2px solid var(--color-yellow); outline-offset: 2px; }

  /* Items list */
  .side-cart-items {
    list-style: none;
    margin: 0;
    padding: 1rem 1.5rem;
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .tray-item {
    display: grid;
    grid-template-columns: 1fr auto auto;
    grid-template-rows: auto auto;
    gap: 0.1rem 0.75rem;
    align-items: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
  }
  .tray-item-name {
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    color: #fff;
    grid-column: 1;
    grid-row: 1;
    font-weight: 400;
  }
  .tray-item-variation {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.4);
    grid-column: 1;
    grid-row: 2;
  }
  .tray-item-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--color-yellow);
    grid-column: 2;
    grid-row: 1 / 3;
    letter-spacing: 0.03em;
  }
  .tray-remove {
    background: none;
    border: none;
    color: rgba(255,255,255,0.2);
    cursor: pointer;
    font-size: 0.75rem;
    padding: 0;
    grid-column: 3;
    grid-row: 1 / 3;
    transition: color 0.15s;
    line-height: 1;
  }
  .tray-remove:hover { color: #ef4444; }

  /* Empty state */
  .side-cart-empty {
    padding: 2rem 1.5rem;
    text-align: center;
    color: rgba(255,255,255,0.3);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .side-cart-empty strong { color: rgba(255,255,255,0.5); }
  .side-cart-empty.hidden { display: none; }

  /* Footer */
  .side-cart-footer {
    padding: 1.25rem 1.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .side-cart-total-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .side-cart-total-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }
  .side-cart-total-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.2rem;
    color: var(--color-yellow);
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .side-cart-disclaimer {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.25);
    line-height: 1.4;
    margin: 0;
  }
  .tray-book {
    display: block;
    text-align: center;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-yellow);
    color: #0e0f14;
    border-radius: 6px;
    padding: 0.85rem;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s, transform 0.15s;
  }
  .tray-book:hover { background: #ffd740; transform: translateY(-1px); }
  .tray-book:focus-visible { outline: 2px solid var(--color-yellow); outline-offset: 2px; }
  .tray-clear {
    display: block;
    width: 100%;
    text-align: center;
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: none;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.35);
    border-radius: 6px;
    padding: 0.55rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .tray-clear:hover { color: #ef4444; border-color: rgba(239,68,68,0.35); }

  /* Backdrop */
  .cart-backdrop {
    position: fixed;
    inset: 0;
    z-index: 95;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .cart-backdrop.open { opacity: 1; pointer-events: all; }

  /* ── Bottom CTA ── */
  .catering-cta {
    background: #14161e;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 5rem 1.5rem;
    text-align: center;
  }
  .cta-inner { max-width: 600px; margin: 0 auto; }
  .cta-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-yellow);
    margin-bottom: 1rem;
  }
  .catering-cta h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .cta-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin-bottom: 2rem;
  }
</style>

<script>
  // ── Filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.menu-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      cards.forEach(card => {
        card.classList.toggle('hidden', filter !== 'all' && card.dataset.category !== filter);
      });
    });
  });

  // ── Variation selector ──
  document.querySelectorAll<HTMLElement>('.menu-card').forEach(card => {
    const varBtns = card.querySelectorAll<HTMLButtonElement>('.variation-btn');
    const priceVal = card.querySelector<HTMLElement>('.price-value');
    varBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        varBtns.forEach(b => { b.classList.remove('selected'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('selected');
        btn.setAttribute('aria-pressed', 'true');
        if (priceVal && btn.dataset.price) priceVal.textContent = btn.dataset.price;
      });
    });
  });

  // ── Side Cart ──
  interface SelectionItem { name: string; variation: string; price: number; }
  let selection: SelectionItem[] = [];

  const cart = document.getElementById('side-cart')!;
  const backdrop = document.getElementById('cart-backdrop')!;
  const cartToggle = document.getElementById('cart-toggle')!;
  const cartClose = document.getElementById('side-cart-close')!;
  const trayItemsList = document.getElementById('tray-items')!;
  const trayTotal = document.getElementById('tray-total')!;
  const trayBook = document.getElementById('tray-book') as HTMLAnchorElement;
  const trayClear = document.getElementById('tray-clear')!;
  const emptyState = document.getElementById('side-cart-empty')!;
  const cartCount = document.getElementById('cart-count')!;

  function openCart() {
    cart.classList.add('open');
    cart.setAttribute('aria-hidden', 'false');
    backdrop.classList.add('open');
    cartClose.focus();
  }
  function closeCart() {
    cart.classList.remove('open');
    cart.setAttribute('aria-hidden', 'true');
    backdrop.classList.remove('open');
    cartToggle.focus();
  }

  cartToggle.addEventListener('click', openCart);
  cartClose.addEventListener('click', closeCart);
  backdrop.addEventListener('click', closeCart);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCart(); });

  function parsePrice(str: string): number {
    const match = str.match(/[\d.]+/);
    return match ? parseFloat(match[0]) : 0;
  }

  function renderCart() {
    trayItemsList.innerHTML = '';
    let total = 0;

    selection.forEach((item, idx) => {
      total += item.price;
      const li = document.createElement('li');
      li.className = 'tray-item';
      li.innerHTML = `
        <span class="tray-item-name">${item.name}</span>
        <span class="tray-item-variation">${item.variation}</span>
        <span class="tray-item-price">$${item.price.toFixed(2)}</span>
        <button class="tray-remove" data-idx="${idx}" aria-label="Remove ${item.name}">✕</button>
      `;
      trayItemsList.appendChild(li);
    });

    trayTotal.textContent = `$${total.toFixed(2)}`;
    cartCount.textContent = String(selection.length);
    cartToggle.hidden = selection.length === 0;
    emptyState.classList.toggle('hidden', selection.length > 0);

    const summary = selection.map(i => `${i.name} (${i.variation}) — $${i.price.toFixed(2)}`).join('\n');
    const encoded = encodeURIComponent('Catering requests:\n' + summary);
    trayBook.href = `/book?catering=true&cateringSelection=${encoded}`;

    trayItemsList.querySelectorAll<HTMLButtonElement>('.tray-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        selection.splice(parseInt(btn.dataset.idx!), 1);
        renderCart();
      });
    });
  }

  // Add button
  document.querySelectorAll<HTMLButtonElement>('.add-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest<HTMLElement>('.menu-card')!;
      const name = btn.dataset.name!;
      const selectedVarBtn = card.querySelector<HTMLButtonElement>('.variation-btn.selected');
      const singleLabel = card.querySelector<HTMLElement>('.variation-single-label');
      const singlePrice = card.querySelector<HTMLElement>('.variation-price');

      let variation = '';
      let price = 0;

      if (selectedVarBtn) {
        variation = selectedVarBtn.textContent?.trim() ?? '';
        price = parsePrice(selectedVarBtn.dataset.price ?? '0');
      } else if (singleLabel && singlePrice) {
        variation = singleLabel.textContent?.trim() ?? '';
        price = parsePrice(singlePrice.textContent ?? '0');
      }

      selection.push({ name, variation, price });
      renderCart();
      openCart();

      btn.textContent = '✓ Added';
      btn.classList.add('added');
      setTimeout(() => {
        btn.textContent = '+ Add to Selection';
        btn.classList.remove('added');
      }, 1500);
    });
  });

  trayClear.addEventListener('click', () => {
    selection = [];
    renderCart();
  });
</script>
