---

<Page
  title="Catering Menu — AllStar Party World"
  description="Build the perfect party spread. Browse our full catering menu — platters, hot foods, pizza, salads, sweets and beverages available for your next event."
>
  <!-- Page Header -->
  <section class="catering-header">
    <div class="header-bg"></div>
    <div class="header-content">
      <p class="eyebrow">Food & Catering</p>
      <h1>Party <span class="accent">Menu</span></h1>
      <p class="header-sub">Build the perfect spread for your event. All items are available for pre-order and served fresh the day of your party.</p>
      <a href="/book?catering=true" class="btn-primary">Request Catering with Your Booking</a>
    </div>
  </section>

  <!-- Notice Banner -->
  <div class="notice-banner">
    <span class="notice-icon">&#9432;</span>
    <span>All catering must be pre-ordered. Pricing shown does not include applicable taxes or service fees. Contact us for custom orders or dietary accommodations.</span>
  </div>

  <!-- Filter Tabs -->
  <nav class="filter-nav" aria-label="Menu categories">
    <div class="filter-inner">
      {categories.map(cat => (
        <button
          class={`filter-btn ${cat.id === 'all' ? 'active' : ''}`}
          data-filter={cat.id}
          aria-pressed={cat.id === 'all' ? 'true' : 'false'}
        >
          {cat.label}
        </button>
      ))}
    </div>
  </nav>

  <!-- Menu Grid -->
  <section class="menu-section">
    <div class="menu-grid">
      {menu.map(item => (
        <article class="menu-card" data-category={item.category} aria-label={item.name}>
          <div class="card-img-wrap">
            <img src={item.image} alt={item.name} class="card-img" loading="lazy" />
            <div class="card-img-overlay"></div>
          </div>
          <div class="card-body">
            <h3 class="card-name">{item.name}</h3>
            <p class="card-desc">{item.description}</p>
            <div class="variations">
              {item.variations.map((v, i) => (
                <div class={`variation-row ${item.variations.length > 1 ? 'has-multiple' : ''}`}>
                  {item.variations.length > 1 && (
                    <button
                      class={`variation-btn ${i === 0 ? 'selected' : ''}`}
                      data-price={v.price}
                      aria-pressed={i === 0 ? 'true' : 'false'}
                    >
                      {v.label}
                    </button>
                  )}
                  {item.variations.length === 1 && (
                    <span class="variation-single-label">{v.label}</span>
                  )}
                  {item.variations.length === 1 && (
                    <span class="variation-price">{v.price}</span>
                  )}
                </div>
              ))}
              {item.variations.length > 1 && (
                <div class="price-display">
                  <span class="price-label">Price:</span>
                  <span class="price-value">{item.variations[0].price}</span>
                </div>
              )}
            </div>
            <button class="card-cta add-btn" data-name={item.name} aria-label={`Add ${item.name} to your selection`}>
              + Add to Selection
            </button>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Cart Toggle Button -->
  <button class="cart-toggle" id="cart-toggle" aria-label="Open catering selection" hidden>
    <span class="cart-toggle-icon">🛒</span>
    <span class="cart-toggle-count" id="cart-count">0</span>
  </button>

  <!-- Side Cart -->
  <aside class="side-cart" id="side-cart" aria-label="Your catering selection" aria-hidden="true">
    <div class="side-cart-header">
      <div>
        <p class="side-cart-eyebrow">Catering</p>
        <h2 class="side-cart-title">Your Selection</h2>
      </div>
      <button class="side-cart-close" id="side-cart-close" aria-label="Close cart">✕</button>
    </div>

    <ul class="side-cart-items" id="tray-items"></ul>

    <div class="side-cart-empty" id="side-cart-empty">
      <p>No items added yet.</p>
      <p>Browse the menu and click <strong>+ Add to Selection</strong>.</p>
    </div>

    <div class="side-cart-footer">
      <div class="side-cart-total-row">
        <span class="side-cart-total-label">Estimated Total</span>
        <span class="side-cart-total-value" id="tray-total">$0.00</span>
      </div>
      <p class="side-cart-disclaimer">*Excludes applicable taxes and service fees. Final pricing confirmed at booking.</p>
      <a class="tray-book" id="tray-book" href="/book?catering=true">Request Catering →</a>
      <button class="tray-clear" id="tray-clear" aria-label="Clear all selections">Clear all items</button>
    </div>
  </aside>

  <!-- Cart Backdrop -->
  <div class="cart-backdrop" id="cart-backdrop"></div>

  <!-- Bottom CTA -->
  <section class="catering-cta">
    <div class="cta-inner">
      <p class="cta-eyebrow">Ready to plan your menu?</p>
      <h2>Let's Build Your<br/><span class="accent">Perfect Party Spread</span></h2>
      <p class="cta-sub">Include your catering selections when you book your event and our team will handle the rest.</p>
      <a href="/book?catering=true" class="btn-primary">Book Your Event + Catering</a>
    </div>
  </section>
</Page>

<style>
  /* ── Header ── */
  .catering-header {
    position: relative;
    padding: 7rem 1.5rem 5rem;
    text-align: center;
    overflow: hidden;
  }
  .header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(245,197,24,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 100%, rgba(232,53,122,0.08) 0%, transparent 60%);
    z-index: 0;
  }
  .header-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }
  .eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-yellow);
    margin-bottom: 1rem;
  }
  .catering-header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .accent { color: var(--color-yellow); }
  .header-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .btn-primary {
    display: inline-block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-yellow);
    color: #0e0f14;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: #ffd740; transform: translateY(-1px); }
  .btn-primary:active { transform: translateY(0); }

  /* ── Notice Banner ── */
  .notice-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    max-width: 1200px;
    margin: 0 auto 0;
    padding: 1rem 1.5rem;
    background: rgba(245,197,24,0.08);
    border: 1px solid rgba(245,197,24,0.2);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
    margin: 0 1.5rem 0;
  }
  @media (min-width: 1248px) {
    .notice-banner { margin: 0 auto; }
  }
  .notice-icon {
    color: var(--color-yellow);
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Filter Nav ── */
  .filter-nav {
    position: sticky;
    top: 72px;
    z-index: 40;
    background: rgba(14,15,20,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 0.75rem 1.5rem;
    margin-top: 1.5rem;
  }
  .filter-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .filter-btn {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .filter-btn:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.25);
  }
  .filter-btn.active {
    background: var(--color-yellow);
    border-color: var(--color-yellow);
    color: #0e0f14;
  }
  .filter-btn:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
  }

  /* ── Menu Grid ── */
  .menu-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1100px) { .menu-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px)  { .menu-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  { .menu-grid { grid-template-columns: 1fr; } }

  /* ── Menu Card ── */
  .menu-card {
    background: #14161e;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .menu-card:hover {
    border-color: rgba(245,197,24,0.3);
    transform: translateY(-2px);
  }
  .menu-card.hidden { display: none; }

  .card-img-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .menu-card:hover .card-img { transform: scale(1.04); }
  .card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(14,15,20,0.6) 0%, transparent 50%);
  }

  .card-body {
    padding: 1rem 1.1rem 1.1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-name {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    margin-bottom: 0.9rem;
    flex: 1;
  }

  /* ── Variations ── */
  .variations { margin-bottom: 0.9rem; }
  .variation-row { display: flex; align-items: center; justify-content: space-between; }
  .variation-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    padding: 0.3rem 0.65rem;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.55);
    cursor: pointer;
    margin-bottom: 0.35rem;
    margin-right: 0.35rem;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    text-align: left;
  }
  .variation-btn:hover {
    border-color: rgba(245,197,24,0.4);
    color: rgba(255,255,255,0.85);
  }
  .variation-btn.selected {
    border-color: var(--color-yellow);
    background: rgba(245,197,24,0.1);
    color: var(--color-yellow);
  }
  .variation-btn:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
  }
  .variation-single-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
  }
  .variation-price {
