    color: var(--color-yellow);
    margin-bottom: 0.2rem;
  }
  .side-cart-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: #fff;
    letter-spacing: 0.03em;
