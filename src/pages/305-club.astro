---
import Page from '../layouts/Page.astro';
---

<Page
  title="The 305 Club — Miami's Premier Nightclub-Style Event Venue"
  description="10,000 sq ft of pure nightclub energy exclusively yours. Professional DJ, GOBO lighting, graffiti wall, and full event production. Quinceañeras, sweet 16s, corporate events & more in Miami."
>

  <!-- ── HERO ── -->
  <section class="hero" aria-label="The 305 Club">
    <div class="hero-bg" aria-hidden="true">
      <video
        src="/305-hero-video.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/305-event-photos/305 dance floor 2.jpg"
        aria-hidden="true"
        class="hero-video"
      ></video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-top-bar" aria-hidden="true"></div>

    <div class="hero-content">
      <span class="eyebrow">02 · Teens &amp; Adults · 8770 SW 131st St, Miami</span>
      <h1 class="hero-headline">
        THE<br>305<br><span class="blue">CLUB.</span>
      </h1>
      <p class="hero-sub">
        <strong>Miami's Premier Party Place.</strong> 10,000 sq ft of pure nightclub energy — exclusively yours. Professional DJ, GOBO lighting, lighted furniture, and a graffiti wall that makes every guest feel like a superstar.
      </p>
      <div class="hero-actions">
        <a href="/book" class="btn-primary"><i class="fa-regular fa-calendar" aria-hidden="true"></i> Book Your Event</a>
        <a href="#packages" class="btn-outline">View Packages</a>
      </div>
      <div class="hero-stats" aria-label="Venue stats">
        <div>
          <div class="hero-stat-num">10K</div>
          <div class="hero-stat-label">Square Feet</div>
        </div>
        <div>
          <div class="hero-stat-num">500+</div>
          <div class="hero-stat-label">Guest Capacity</div>
        </div>
        <div>
          <div class="hero-stat-num">1,000+</div>
          <div class="hero-stat-label">Events Hosted</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section class="about-section" aria-label="About the Venue">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-img">
          <img src="/305-event-photos/305 quinces.jpg" alt="Quinceañera celebration inside The 305 Club" />
        </div>
        <div class="about-copy">
          <p class="section-eyebrow">About The Venue</p>
          <h2 class="section-title">Let's Get The<br><span class="accent">Party Started.</span></h2>
          <p class="section-body">We want to host your special event and turn it into something your family and friends will be talking about for years. With up to 10,000 sq ft of space, a full VIP experience, and a team that handles setup, service, and cleanup — all you have to do is show up and feel like a superstar.</p>
          <p class="section-body" style="margin-top:1rem;">Looking for a fun place for your teen to celebrate without the stress of uninvited guests? The 305 Club is the right place. We keep it safe, exclusive, and electric — every time.</p>
          <div class="about-actions">
            <a href="/book" class="btn-primary"><i class="fa-regular fa-calendar" aria-hidden="true"></i> Book Your Event</a>
            <a href="tel:+17864710100" class="btn-outline"><i class="fa-solid fa-phone" aria-hidden="true"></i> (786) 471-0100</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" aria-hidden="true"></div>

  <!-- ── PHOTO STRIP ── -->
  <div class="photo-strip" aria-label="Venue photos">
    <div class="photo-strip-inner">
      <div class="photo-strip-item">
        <img src="/305-event-photos/305 dance floor.jpg" alt="305 Club dance floor" loading="lazy" />
        <div class="photo-strip-overlay" aria-hidden="true"></div>
        <div class="photo-strip-label">Dance Floor</div>
      </div>
      <div class="photo-strip-item">
        <img src="/305-event-photos/305 15 b-day.jpg" alt="15th birthday celebration" loading="lazy" />
        <div class="photo-strip-overlay" aria-hidden="true"></div>
        <div class="photo-strip-label">Sweet 16s</div>
      </div>
      <div class="photo-strip-item">
        <img src="/305-event-photos/305 360 photo booth.jpg" alt="360 degree photo booth" loading="lazy" />
        <div class="photo-strip-overlay" aria-hidden="true"></div>
        <div class="photo-strip-label">360° Photo Booth</div>
      </div>
      <div class="photo-strip-item">
        <img src="/305-event-photos/305 event food.jpg" alt="Event catering" loading="lazy" />
        <div class="photo-strip-overlay" aria-hidden="true"></div>
        <div class="photo-strip-label">Catering</div>
      </div>
      <div class="photo-strip-item">
        <img src="/305-event-photos/305 58th b-day.jpg" alt="Birthday balloon arch" loading="lazy" />
        <div class="photo-strip-overlay" aria-hidden="true"></div>
        <div class="photo-strip-label">Balloon Décor</div>
      </div>
    </div>
  </div>

  <div class="divider" aria-hidden="true"></div>

  <!-- ── EVENTS WE HOST ── -->
  <section id="events" class="events-section" aria-label="Events We Host">
    <div class="section-inner">
      <p class="section-eyebrow">What We Host</p>
      <h2 class="section-title">Your Event.<br><span class="accent">Our Expertise.</span></h2>
      <div class="events-grid">

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 quinces.jpg" alt="Quinceañera celebration" loading="lazy" />
          </div>
          <div class="event-card-body">
            <div class="event-tag">Signature Event</div>
            <h3 class="event-title">Quinceañeras</h3>
            <p class="event-desc">Her night. Her crown. Our stage. Full production, custom décor, and a celebration that'll have her family talking for years.</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 15 b-day.jpg" alt="Sweet sixteen party" loading="lazy" />
          </div>
          <div class="event-card-body">
            <div class="event-tag">Teen Celebration</div>
            <h3 class="event-title">Sweet Sixteens</h3>
            <p class="event-desc">The hottest sweet 16 in Miami starts here. Real club energy, live DJ, and an experience that makes 16 feel like a headline moment.</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 58th b-day.jpg" alt="Private birthday party" loading="lazy" />
          </div>
          <div class="event-card-body">
            <div class="event-tag">Private Party</div>
            <h3 class="event-title">Birthday Parties</h3>
            <p class="event-desc">Turn any age into a legendary night. The whole venue is yours — no strangers, no limits, just your people celebrating you.</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 13th b-day 2.jpg" alt="Graduation party celebration" loading="lazy" />
          </div>
          <div class="event-card-body">
            <div class="event-tag">Milestone</div>
            <h3 class="event-title">Graduation Parties</h3>
            <p class="event-desc">You earned it — celebrate like it. Bring your class together for a graduation night that actually matches the achievement.</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 event 13th b-day.jpg" alt="Dance floor event" loading="lazy" />
          </div>
          <div class="event-card-body">
            <div class="event-tag">Cultural</div>
            <h3 class="event-title">Bar &amp; Bat Mitzvahs</h3>
            <p class="event-desc">Honor the tradition and elevate the celebration. We create a night that blends meaning with pure Miami energy.</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 dance floor.jpg" alt="Corporate event" loading="lazy" />
          </div>
          <div class="event-card-body">
            <div class="event-tag">Corporate</div>
            <h3 class="event-title">Corporate &amp; Holiday</h3>
            <p class="event-desc">Ditch the ballroom. Impress your team and clients with a venue that actually excites people — company parties, launches, and holiday events done right.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ── -->
  <div class="stats-strip" aria-label="Quick stats">
    <div class="stats-inner">
      <div>
        <div class="stat-num">10K</div>
        <div class="stat-label">Square Feet</div>
      </div>
      <div>
        <div class="stat-num">500+</div>
        <div class="stat-label">Guest Capacity</div>
      </div>
      <div>
        <div class="stat-num">1,000+</div>
        <div class="stat-label">Events Hosted</div>
      </div>
      <div>
        <div class="stat-num">5★</div>
        <div class="stat-label">Average Rating</div>
      </div>
    </div>
  </div>

  <!-- ── WHAT'S INCLUDED ── -->
  <section id="packages" class="included-section" aria-label="What's Included">
    <div class="section-inner">
      <p class="section-eyebrow">What's Included</p>
      <h2 class="section-title">Everything You Need<br><span class="accent">All In One Place</span></h2>
      <p class="section-body">Every event at The 305 Club comes with full production and a dedicated team — so you can focus on the celebration.</p>

      <div class="included-grid">
        <div class="included-cell">
          <div class="included-num">10K SQ FT</div>
          <div class="included-title">Private Venue</div>
          <div class="included-desc">Fully private — no public, no strangers. The whole space is yours.</div>
        </div>
        <div class="included-cell">
          <div class="included-num">500+</div>
          <div class="included-title">Guest Capacity</div>
          <div class="included-desc">Intimate gatherings or large celebrations — we scale to your event.</div>
        </div>
        <div class="included-cell">
          <div class="included-num">PRO DJ</div>
          <div class="included-title">Professional DJ</div>
          <div class="included-desc">Club-grade sound system. Custom playlists tailored to your vibe.</div>
        </div>
        <div class="included-cell">
          <div class="included-num">GOBO</div>
          <div class="included-title">Lighting &amp; TV Wall</div>
          <div class="included-desc">Personalized light shows and TV wall displays throughout the night.</div>
        </div>
        <div class="included-cell">
          <div class="included-num">WALL</div>
          <div class="included-title">Graffiti Wall</div>
          <div class="included-desc">Interactive signature wall — a photo moment every single guest loves.</div>
        </div>
        <div class="included-cell">
          <div class="included-num">STAFF</div>
          <div class="included-title">Full Event Team</div>
          <div class="included-desc">Setup, service, and cleanup all handled. Your only job is to enjoy.</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" aria-hidden="true"></div>

  <!-- ── GALLERY PREVIEW ── -->
  <section class="gallery-section" aria-label="Gallery Preview">
    <div class="section-inner">
      <p class="section-eyebrow">See It In Action</p>
      <h2 class="section-title">Real Events.<br><span class="accent">Real Memories.</span></h2>

      <div class="gallery-grid">
        <div class="gallery-item span2 tall">
          <img src="/305-event-photos/305 dance floor 2.jpg" alt="305 Club dance floor packed with guests" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">The 305 Club</div>
        </div>
        <div class="gallery-item">
          <img src="/305-event-photos/305 10th b-day.jpg" alt="Neon themed birthday party" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Neon Birthday</div>
        </div>
        <div class="gallery-item">
          <img src="/305-event-photos/305 event halloween.jpg" alt="Halloween themed event" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Themed Events</div>
        </div>
        <div class="gallery-item">
          <img src="/305-event-photos/305 event halloween 2.jpg" alt="Halloween decor" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Custom Décor</div>
        </div>
        <div class="gallery-item">
          <img src="/305-event-photos/305 holloween 3.jpg" alt="Halloween setup" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Event Setup</div>
        </div>
      </div>

      <div style="text-align:center; margin-top:2rem;">
        <a href="/gallery" class="btn-outline">View Full Gallery →</a>
      </div>
    </div>
  </section>

  <div class="divider" aria-hidden="true"></div>

  <!-- ── CTA ── -->
  <section id="book" class="cta-section" aria-label="Book your event">
    <div class="section-inner" style="text-align:center;padding-top:4rem;padding-bottom:4rem;">
      <p class="section-eyebrow">Ready to Celebrate?</p>
      <h2 class="section-title">Let's Make It<br><span class="accent">Unforgettable.</span></h2>
      <p class="cta-body">Fill out our booking form and our team will reach out within 24 hours with availability, pricing, and a custom proposal.</p>
      <div class="cta-actions">
        <a href="/book" class="btn-primary"><i class="fa-regular fa-calendar" aria-hidden="true"></i> Book Your Event</a>
        <a href="tel:+17864710100" class="btn-outline"><i class="fa-solid fa-phone" aria-hidden="true"></i> (786) 471-0100</a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="faq-section" aria-label="Frequently Asked Questions">
    <div class="section-inner faq-header-inner">
      <div style="text-align:center;">
        <p class="section-eyebrow">Questions</p>
        <h2 class="section-title" style="margin-bottom:0;">Frequently Asked</h2>
      </div>
    </div>
    <div class="faq-list-wrap">
      <div class="faq-list" role="list">

        <div class="faq-item" role="listitem">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-305-1">
            <span>Who is The 305 Club for?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id="faq-305-1" role="region">
            <div class="faq-answer-inner">Teens and adults — we specialize in making anyone feel like a superstar. From quinceañeras and sweet 16s to corporate events and holiday parties, if you want a night your guests won't stop talking about, this is your venue.</div>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-305-2">
            <span>How far in advance should I book?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id="faq-305-2" role="region">
            <div class="faq-answer-inner">The sooner the better — Friday and Saturday dates book months out. We recommend reaching out at least 3–6 months ahead for large events. A deposit locks in your date.</div>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-305-3">
            <span>What's included in the venue rental?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id="faq-305-3" role="region">
            <div class="faq-answer-inner">Your rental includes the full 10,000 sq ft space, lighted furniture, our graffiti wall, GOBO and TV wall displays, professional DJ equipment, event staff, setup, and cleanup. It's a full-production venue — not just a room.</div>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-305-4">
            <span>Do you offer catering?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id="faq-305-4" role="region">
            <div class="faq-answer-inner">Yes — we have a full catering menu available. Our team works with you to customize food and beverage options for your event. Outside catering is also available with prior approval.</div>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-305-5">
            <span>Can you host unique events like pop-up museums or live shows?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id="faq-305-5" role="region">
            <div class="faq-answer-inner">Absolutely. Beyond private parties, we've hosted pop-up museums, live musical events, and acting playhouse productions. Our space is flexible and our team has the experience to make unconventional events work beautifully.</div>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-305-6">
            <span>Do you have a kids venue nearby?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id="faq-305-6" role="region">
            <div class="faq-answer-inner">Yes — All Star Party World is our sister venue for kids ages 4–12. Perfect for multi-generational events: kids party at All Star while the adults celebrate at The 305 Club. One call handles both.</div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Page>

<style>
  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .section-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #3B7DEB;
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.2rem, 4vw, 4rem);
    line-height: 0.95;
    margin-bottom: 1rem;
  }
  .section-title .accent { color: #7fb3ff; }

  .section-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
    max-width: 540px;
  }

  .divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent); }

  /* BUTTONS */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #3B7DEB; color: #fff; padding: 0.9rem 2rem; border-radius: 8px;
    font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.9rem;
    letter-spacing: 0.04em; text-decoration: none;
    box-shadow: 0 0 24px rgba(59,125,235,0.4), 0 4px 16px rgba(0,0,0,0.3);
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(59,125,235,0.6), 0 8px 24px rgba(0,0,0,0.4); }
  .btn-primary:active { transform: translateY(0); }

  .btn-outline {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: transparent; color: #fff; padding: 0.9rem 2rem; border-radius: 8px;
    font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.9rem;
    letter-spacing: 0.04em; text-decoration: none; border: 1px solid rgba(255,255,255,0.2);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-outline:hover { border-color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.05); transform: translateY(-2px); }

  /* HERO */
  .hero {
    min-height: 100vh; position: relative;
    display: flex; align-items: flex-end;
    padding: 0 2rem 5rem;
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img, .hero-video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(14,15,20,1) 0%, rgba(14,15,20,0.5) 40%, rgba(14,15,20,0.3) 100%);
  }
  .hero-top-bar {
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, #3B7DEB, #E8357A);
  }
  .hero-content { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; width: 100%; }

  .eyebrow {
    display: block; font-family: 'Oswald', sans-serif;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; color: #7fb3ff; margin-bottom: 1.25rem;
  }

  .hero-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 10vw, 9rem);
    line-height: 0.88; letter-spacing: -0.01em; margin-bottom: 1.25rem;
  }
  .hero-headline .blue { color: #7fb3ff; }

  .hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    color: rgba(255,255,255,0.55); line-height: 1.7;
    max-width: 520px; margin-bottom: 2rem;
  }
  .hero-sub strong { color: rgba(255,255,255,0.85); }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .hero-stats { display: flex; gap: 3rem; flex-wrap: wrap; }

  .hero-stat-num {
    font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: #7fb3ff; line-height: 1;
  }
  .hero-stat-label {
    font-family: 'DM Sans', sans-serif; font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35);
  }

  /* ABOUT */
  .about-section { background: #0e0f14; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-img { border-radius: 14px; overflow: hidden; aspect-ratio: 4/3; border: 1px solid rgba(255,255,255,0.08); }
  .about-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .about-actions { margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap; }

  /* PHOTO STRIP */
  .photo-strip { background: #0e0f14; overflow: hidden; }
  .photo-strip-inner { display: grid; grid-template-columns: repeat(5, 1fr); height: 280px; gap: 4px; }
  .photo-strip-item { position: relative; overflow: hidden; }
  .photo-strip-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94); }
  .photo-strip-item:hover img { transform: scale(1.06); }
  .photo-strip-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%); }
  .photo-strip-label { position: absolute; bottom: 0.75rem; left: 0.75rem; font-family: 'Oswald', sans-serif; font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.9); letter-spacing: 0.06em; }

  /* EVENTS */
  .events-section { background: #14161e; position: relative; overflow: hidden; }
  .events-section::before { content: ''; position: absolute; top: -200px; right: -200px; width: 600px; height: 600px; background: radial-gradient(circle, rgba(59,125,235,0.08) 0%, transparent 70%); pointer-events: none; }

  .events-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2.5rem; }

  .event-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px; overflow: hidden;
    will-change: transform;
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), border-color 0.3s ease;
  }
  .event-card:hover { transform: translateY(-4px); border-color: rgba(59,125,235,0.3); }

  .event-card-img { height: 180px; overflow: hidden; }
  .event-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94); }
