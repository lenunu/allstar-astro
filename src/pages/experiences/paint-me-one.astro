---
import Page from '../../layouts/Page.astro';
---

<Page
  title="Paint Me One — Neon Blacklight Art Experience | All Star Party World"
  description="Step into an immersive blacklight paint studio. Kids wear smocks, grab brushes, and create glowing neon masterpieces on canvas while surrounded by explosion of UV color. A one-of-a-kind party experience in Miami."
>

  <!-- Hero -->
  <section class="pmo-hero" aria-label="Paint Me One experience hero">
    <div class="pmo-hero-bg" aria-hidden="true">
      <img src="/pmo-hero.webp" alt="" />
      <div class="pmo-hero-overlay"></div>
    </div>
    <div class="pmo-hero-content">
      <div class="pmo-eyebrow hi-0">Signature Experience</div>
      <h1 class="pmo-hero-title hi-1">Paint<br /><span class="pmo-accent">Me One</span></h1>
      <p class="pmo-hero-sub hi-2">An immersive blacklight neon art studio inside All Star Party World. Every kid leaves with a glowing canvas masterpiece — and memories that glow just as bright.</p>
      <div class="pmo-hero-actions hi-3">
        <a href="/book" class="btn-primary">Add to Your Party</a>
        <a href="#gallery" class="btn-ghost">See Photos</a>
      </div>
    </div>
    <div class="pmo-hero-scroll" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- What Is It -->
  <section class="pmo-what" aria-label="About Paint Me One">
    <div class="pmo-what-inner">
      <div class="pmo-what-text about-copy">
        <div class="section-eyebrow">The Experience</div>
        <h2>Where Art Meets <span class="pmo-accent">Blacklight Magic</span></h2>
        <p>Paint Me One is unlike any art class you've seen. Kids step into a room completely transformed by UV blacklights — neon paint splattered across every wall, ceiling to floor. Wearing white lab coats and hair nets, they pick up brushes and paint on their own canvas while the whole room pulses with color.</p>
        <p>No experience needed. No rules. Just pure, glowing creative expression that kids talk about for months.</p>
        <ul class="pmo-feature-list" role="list">
          <li><span class="check-icon" aria-hidden="true">✦</span> White lab coat + hair net provided</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Personal canvas to take home</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Neon UV paints in every color</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Full blacklight immersion room</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Guided by All Star specialists</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Ages 4 and up</li>
        </ul>
        <a href="/book" class="btn-primary" style="margin-top:1.5rem;display:inline-flex;">Book This Experience</a>
      </div>
      <div class="pmo-what-image about-img">
        <img src="/pmo-side.webp" alt="Child painting on a large canvas in the neon blacklight Paint Me One room" />
        <div class="pmo-image-badge" aria-hidden="true">
          <span class="badge-num">4+</span>
          <span class="badge-label">Ages</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Strip -->
  <section class="pmo-strip" aria-label="Paint Me One photo gallery">
    <div class="pmo-strip-grid">
      <div class="pmo-strip-item tall">
        <img src="/paintmeone-photos/kids-group-blacklight-paint-room.jpg" alt="Large group of kids in white smocks standing in the neon paint-splattered blacklight room" loading="lazy" />
      </div>
      <div class="pmo-strip-item">
        <img src="/paintmeone-photos/kids-painting-canvases-neon-wall.jpg" alt="Kids painting on canvases in front of the neon splatter wall under UV blacklights" loading="lazy" />
      </div>
      <div class="pmo-strip-item">
        <img src="/paintmeone-photos/girl-painting-canvas-closeup.jpg" alt="Close-up of a girl painting her canvas with neon paint in the blacklight room" loading="lazy" />
      </div>
      <div class="pmo-strip-item">
        <img src="/paintmeone-photos/kids-white-smocks-painting.jpg" alt="Kids in white lab coats painting canvases surrounded by glowing neon walls" loading="lazy" />
      </div>
      <div class="pmo-strip-item">
        <img src="/paintmeone-photos/girl-smiling-paint-room.jpg" alt="Girl smiling in white smock inside the neon blacklight Paint Me One room" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="pmo-steps" aria-label="How Paint Me One works">
    <div class="pmo-steps-inner">
      <div class="section-eyebrow" style="text-align:center;">How It Works</div>
      <h2 style="text-align:center;margin-bottom:3rem;">Three Steps to <span class="pmo-accent">Glow</span></h2>
      <div class="pmo-steps-grid" role="list">
        <div class="pmo-step" role="listitem">
          <div class="step-num" aria-hidden="true">01</div>
          <div class="step-icon" aria-hidden="true"><i class="fas fa-user-astronaut"></i></div>
          <h3>Gear Up</h3>
          <p>Each child receives a white lab coat and hair net. The transformation begins before they even touch a brush.</p>
        </div>
        <div class="pmo-step" role="listitem">
          <div class="step-num" aria-hidden="true">02</div>
          <div class="step-icon" aria-hidden="true"><i class="fas fa-paint-brush"></i></div>
          <h3>Create</h3>
          <p>Step into the blacklight room, grab neon paints, and go. The walls, ceiling, and floor are already a glowing masterpiece — add yours to it.</p>
        </div>
        <div class="pmo-step" role="listitem">
          <div class="step-num" aria-hidden="true">03</div>
          <div class="step-icon" aria-hidden="true"><i class="fas fa-star"></i></div>
          <h3>Take It Home</h3>
          <p>Every child leaves with their finished canvas — a unique, glowing neon artwork that's 100% theirs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Add-On Banner -->
  <section class="pmo-addon" aria-label="Add Paint Me One to your party">
    <div class="pmo-addon-inner">
      <div class="pmo-addon-text">
        <div class="section-eyebrow">Party Add-On</div>
        <h2>Add It to Any Party Package</h2>
        <p>Paint Me One is available as a premium add-on to any All Star Party World package. Your guests paint, create, and leave with a glowing souvenir — all while your party keeps going in the main venue.</p>
        <p>Available for private parties only. Ask about pricing when you book.</p>
        <a href="/book" class="btn-primary">Get a Quote</a>
      </div>
      <div class="pmo-addon-details" role="list" aria-label="What's included">
        <div class="detail-card" role="listitem">
          <i class="fas fa-clock" aria-hidden="true"></i>
          <div>
            <strong>Duration</strong>
            <span>~45 min session</span>
          </div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-users" aria-hidden="true"></i>
          <div>
            <strong>Group Size</strong>
            <span>Up to 20 kids</span>
          </div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-child" aria-hidden="true"></i>
          <div>
            <strong>Age Range</strong>
            <span>Ages 4 and up</span>
          </div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
          <div>
            <strong>Location</strong>
            <span>Inside All Star Party World</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Anchor -->
  <div id="gallery" aria-hidden="true" style="height:0;overflow:hidden;"></div>

  <!-- Other Experiences -->
  <section class="pmo-more" aria-label="More signature experiences">
    <div class="pmo-more-inner">
      <div class="section-eyebrow" style="text-align:center;">More Experiences</div>
      <h2 style="text-align:center;margin-bottom:2.5rem;">Keep the <span class="pmo-accent">Fun Going</span></h2>
      <div class="pmo-more-grid">
        <a href="/experiences/karaoke-lounge" class="more-card" aria-label="Karaoke Lounge experience">
          <div class="more-card-icon" aria-hidden="true"><i class="fas fa-microphone"></i></div>
          <div class="more-card-content">
            <h3>Karaoke Lounge</h3>
            <p>Professional mics, stage lighting, and a massive song library. Your little stars perform live.</p>
          </div>
          <span class="more-card-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/experiences/pop-star-divas" class="more-card" aria-label="Pop Star Divas experience">
          <div class="more-card-icon" aria-hidden="true"><i class="fas fa-crown"></i></div>
          <div class="more-card-content">
            <h3>Pop Star Divas</h3>
            <p>Glam makeup, diva costumes, and a full pop star photo shoot moment they'll never forget.</p>
          </div>
          <span class="more-card-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/experiences/vr-experience" class="more-card" aria-label="VR Experience">
          <div class="more-card-icon" aria-hidden="true"><i class="fas fa-vr-cardboard"></i></div>
          <div class="more-card-content">
            <h3>VR Experience</h3>
            <p>Strap on a headset and step into another world. Racing, adventures, and more in full virtual reality.</p>
          </div>
          <span class="more-card-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pmo-cta" aria-label="Book Paint Me One">
    <div class="pmo-cta-bg" aria-hidden="true">
      <img src="/pmo-hero.webp" alt="" />
      <div class="pmo-cta-overlay"></div>
    </div>
    <div class="pmo-cta-content">
      <h2>Ready to <span class="pmo-accent">Glow?</span></h2>
      <p>Book your party and add the Paint Me One experience. Available exclusively at All Star Party World.</p>
      <div class="pmo-cta-actions">
        <a href="/book" class="btn-primary">Book Now</a>
        <a href="tel:+17864710100" class="btn-ghost">
          <i class="fas fa-phone" aria-hidden="true"></i>
          786-471-0100
        </a>
      </div>
    </div>
  </section>

</Page>

<style>
  /* ── Design tokens ── */
  :root {
    --pmo-accent: #E8357A;
    --pmo-accent2: #F5C518;
    --pmo-glow: rgba(232,53,122,0.35);
  }

  .pmo-accent { color: var(--pmo-accent); }

  .section-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pmo-accent);
    margin-bottom: 0.75rem;
  }

  /* ── Hero ── */
  .pmo-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .pmo-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .pmo-hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .pmo-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(8,9,16,0.85) 0%, rgba(8,9,16,0.4) 60%, transparent 100%),
      linear-gradient(to top, rgba(8,9,16,0.7) 0%, transparent 40%),
      linear-gradient(to bottom, rgba(8,9,16,0.4) 0%, transparent 30%);
  }

  .pmo-hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    padding: 8rem clamp(2rem, 8vw, 7rem) 6rem;
  }

  .pmo-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--pmo-accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .pmo-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: var(--pmo-accent);
    border-radius: 2px;
  }

  .pmo-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 14vw, 11rem);
    line-height: 0.85;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0 0 1.5rem;
    text-shadow: 0 0 60px var(--pmo-glow);
  }
  .pmo-hero-title .pmo-accent {
    display: block;
    -webkit-text-stroke: 2px var(--pmo-accent);
    color: transparent;
    text-shadow: 0 0 80px var(--pmo-glow);
  }

  .pmo-hero-sub {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.75);
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .pmo-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .pmo-hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 0.8; transform: scaleY(1.1); }
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--pmo-accent);
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 0 24px rgba(232,53,122,0.4), 0 4px 12px rgba(0,0,0,0.3);
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 40px rgba(232,53,122,0.6), 0 8px 24px rgba(0,0,0,0.4);
  }
  .btn-primary:focus-visible { outline: 2px solid var(--pmo-accent); outline-offset: 3px; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.7);
    padding: 0.75rem 1.75rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.5); transform: translateY(-2px); }
  .btn-ghost:focus-visible { outline: 2px solid rgba(255,255,255,0.5); outline-offset: 3px; }

  /* ── What Is It ── */
  .pmo-what {
    background: #0e0f14;
    padding: 7rem 2rem;
  }
  .pmo-what-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .pmo-what-text h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
  }
  .pmo-what-text p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1rem;
  }
  .pmo-feature-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .pmo-feature-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
  }
  .check-icon { color: var(--pmo-accent); font-size: 0.65rem; flex-shrink: 0; }

  .pmo-what-image {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    will-change: transform;
  }
  .pmo-what-image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }
  .pmo-image-badge {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    background: var(--pmo-accent);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    text-align: center;
    box-shadow: 0 8px 32px rgba(232,53,122,0.5);
  }
  .badge-num {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    line-height: 1;
    color: #fff;
  }
  .badge-label {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
  }

  /* ── Photo Strip ── */
  .pmo-strip { background: #080910; padding: 0; }
  .pmo-strip-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    grid-template-rows: 280px;
    gap: 4px;
  }
  .pmo-strip-item { overflow: hidden; }
  .pmo-strip-item.tall { grid-row: span 1; }
  .pmo-strip-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .pmo-strip-item:hover img { transform: scale(1.05); }

  /* ── Steps ── */
  .pmo-steps {
    background: #14161e;
    padding: 7rem 2rem;
  }
  .pmo-steps-inner { max-width: 1280px; margin: 0 auto; }
  .pmo-steps-inner h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
  }
  .pmo-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .pmo-step {
    position: relative;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 2rem;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  }
  .pmo-step:hover { border-color: rgba(232,53,122,0.3); transform: translateY(-4px); }
  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 5rem;
    line-height: 1;
    color: rgba(232,53,122,0.08);
    position: absolute;
    top: 0.5rem;
    right: 1rem;
    pointer-events: none;
  }
  .step-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: rgba(232,53,122,0.15);
    border: 1px solid rgba(232,53,122,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: var(--pmo-accent);
    margin-bottom: 1.25rem;
  }
  .pmo-step h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .pmo-step p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.6);
  }

  /* ── Add-On ── */
  .pmo-addon {
    background: #0e0f14;
    padding: 7rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .pmo-addon-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .pmo-addon-text h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 1.25rem;
  }
  .pmo-addon-text p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1rem;
  }
  .pmo-addon-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .detail-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    transition: border-color 0.2s ease;
  }
  .detail-card:hover { border-color: rgba(232,53,122,0.25); }
  .detail-card i {
    font-size: 1.1rem;
    color: var(--pmo-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .detail-card div { display: flex; flex-direction: column; gap: 0.25rem; }
  .detail-card strong {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .detail-card span {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
  }

  /* ── More Experiences ── */
  .pmo-more {
    background: #14161e;
    padding: 7rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .pmo-more-inner { max-width: 1280px; margin: 0 auto; }
  .pmo-more-inner h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
  }
  .pmo-more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .more-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    will-change: transform;
