---
import Page from '../../layouts/Page.astro';
---

<Page
  title="PopStar Divas — Design • Dazzle • Dance | The 305 Club"
  description="Where every kid feels like a STAR! Glam dress-up, DIY crafts, music, dancing, photo booth, and VIP entrance into The 305 Club. The ultimate pop star party experience in Miami."
>

  <!-- Hero -->
  <section class="psd-hero" aria-label="PopStar Divas hero">
    <div class="psd-hero-bg" aria-hidden="true">
      <img src="/popstar-hero.webp" alt="" class="psd-hero-img" />
      <div class="psd-hero-overlay"></div>
    </div>
    <div class="psd-hero-content">
      <div class="psd-eyebrow hi-0">Signature Experience</div>
      <h1 class="psd-hero-title hi-1">Pop Star<br /><span class="psd-accent">Divas</span></h1>
      <p class="psd-hero-sub hi-2">Let your child and their friends live out their pop-star dreams. This all-in-one party package brings the sparkle, style, and energy to create unforgettable birthday memories.</p>
      <div class="psd-hero-actions hi-3">
        <a href="/book" class="btn-primary">Book This Experience</a>
        <a href="#what-it-is" class="btn-ghost">Learn More</a>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="psd-what" id="what-it-is" aria-label="What's included in PopStar Divas">
    <div class="psd-what-inner">
      <div class="psd-what-text about-copy">
        <div class="section-eyebrow">Your Private Party Includes</div>
        <h2>The Ultimate <span class="psd-accent">Pop Star Party</span></h2>
        <p>PopStar Divas at The 305 Club is the ultimate birthday experience. Every detail is designed to make your child and her friends feel like real pop stars — from the runway to the dance floor.</p>
        <ul class="psd-feature-list" role="list">
          <li>
            <span class="feat-icon" aria-hidden="true"><i class="fas fa-gem"></i></span>
            <div>
              <strong>Glam Dress-Up &amp; Runway Show</strong>
              <span>Dress up in our glam accessories for a dazzling runway show moment</span>
            </div>
          </li>
          <li>
            <span class="feat-icon" aria-hidden="true"><i class="fas fa-palette"></i></span>
            <div>
              <strong>DIY Sunglasses or Jewelry Crafts</strong>
              <span>Take home a one-of-a-kind creation they designed themselves</span>
            </div>
          </li>
          <li>
            <span class="feat-icon" aria-hidden="true"><i class="fas fa-music"></i></span>
            <div>
              <strong>Music &amp; Dancing Fun</strong>
              <span>High-energy dance party with the best hits</span>
            </div>
          </li>
          <li>
            <span class="feat-icon" aria-hidden="true"><i class="fas fa-camera"></i></span>
            <div>
              <strong>Photo Booth</strong>
              <span>Strike a pose and capture every star moment</span>
            </div>
          </li>
          <li>
            <span class="feat-icon" aria-hidden="true"><i class="fas fa-star"></i></span>
            <div>
              <strong>VIP Entrance into The 305 Club</strong>
              <span>Red carpet treatment — because every diva deserves the royal welcome</span>
            </div>
          </li>
        </ul>
        <a href="/book" class="btn-primary" style="margin-top:2rem;display:inline-flex;">Book This Experience</a>
      </div>
      <div class="psd-what-image about-img">
        <img src="/popstar-includes.webp" alt="PopStar Divas party accessories: crown, sunglasses, disco ball, camera, and glam props" class="psd-includes-photo" />
        <div class="psd-image-badge" aria-hidden="true">
          <span class="badge-star"><i class="fas fa-star"></i></span>
          <span class="badge-label">VIP Party</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Party Details -->
  <section class="psd-addon" aria-label="PopStar Divas party details">
    <div class="psd-addon-inner">
      <div class="psd-addon-text">
        <div class="section-eyebrow">Party Details</div>
        <h2>Where every kid<br />feels like a <span class="psd-accent">STAR!</span></h2>
        <p>PopStar Divas is an exclusive private party experience at The 305 Club. Book the experience as a standalone celebration or combine it with any All Star Party World package for the ultimate party day.</p>
        <a href="/book" class="btn-primary">Get a Quote</a>
      </div>
      <div class="psd-addon-details" role="list">
        <div class="detail-card" role="listitem">
          <i class="fas fa-clock" aria-hidden="true"></i>
          <div><strong>Duration</strong><span>Private session</span></div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-users" aria-hidden="true"></i>
          <div><strong>Group Size</strong><span>Private party</span></div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-child" aria-hidden="true"></i>
          <div><strong>Age Range</strong><span>Kids &amp; tweens</span></div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
          <div><strong>Location</strong><span>The 305 Club</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- More Experiences -->
  <section class="psd-more" aria-label="More signature experiences">
    <div class="psd-more-inner">
      <div class="section-eyebrow" style="text-align:center;">More Experiences</div>
      <h2 style="text-align:center;margin-bottom:2.5rem;">Keep the <span class="psd-accent">Fun Going</span></h2>
      <div class="psd-more-grid">
        <a href="/experiences/paint-me-one" class="more-card">
          <div class="more-card-icon"><i class="fas fa-paint-brush"></i></div>
          <div class="more-card-content"><h3>Paint Me One</h3><p>Blacklight neon art studio. Kids paint glowing canvases they take home.</p></div>
          <span class="more-card-arrow">→</span>
        </a>
        <a href="/experiences/karaoke-lounge" class="more-card">
          <div class="more-card-icon"><i class="fas fa-microphone"></i></div>
          <div class="more-card-content"><h3>Karaoke Lounge</h3><p>Professional mics and stage lighting. Every guest gets their pop star moment at the mic.</p></div>
          <span class="more-card-arrow">→</span>
        </a>
        <a href="/experiences/vr-experience" class="more-card">
          <div class="more-card-icon"><i class="fas fa-vr-cardboard"></i></div>
          <div class="more-card-content"><h3>VR Experience</h3><p>Strap on a headset and step into another world. Racing, adventures, and more.</p></div>
          <span class="more-card-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="psd-cta" aria-label="Book PopStar Divas">
    <div class="psd-cta-content">
      <p class="psd-cta-slogan">Where every kid feels like a STAR!</p>
      <h2>Ready to <span class="psd-accent">Shine?</span></h2>
      <p class="psd-cta-sub">Book your PopStar Divas party at The 305 Club. Call us or fill out the booking form and we'll take care of every sparkly detail.</p>
      <div class="psd-cta-actions">
        <a href="/book" class="btn-primary">Book Now</a>
        <a href="tel:+17864710100" class="btn-ghost"><i class="fas fa-phone" aria-hidden="true"></i> 786-471-0100</a>
      </div>
    </div>
  </section>

</Page>

<style>
  :root { --psd-accent: #E8357A; --psd-glow: rgba(232,53,122,0.4); }
  .psd-accent { color: var(--psd-accent); }
  .section-eyebrow {
    font-family: 'Oswald', sans-serif; font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--psd-accent); margin-bottom: 0.75rem;
  }

  /* ── Hero ── */
  .psd-hero { position: relative; min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
  .psd-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .psd-hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center 25%; display: block; }
  .psd-hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(8,9,16,0.88) 0%, rgba(8,9,16,0.55) 55%, rgba(8,9,16,0.2) 100%),
      linear-gradient(to top, rgba(8,9,16,0.75) 0%, transparent 45%),
      linear-gradient(to bottom, rgba(8,9,16,0.45) 0%, transparent 30%);
  }
  .psd-hero-content {
    position: relative; z-index: 1; max-width: 680px;
    padding: 8rem clamp(2rem, 8vw, 7rem) 6rem;
  }
  .psd-eyebrow {
    font-family: 'Oswald', sans-serif; font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--psd-accent);
    margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.75rem;
  }
  .psd-eyebrow::before { content: ''; display: block; width: 32px; height: 2px; background: var(--psd-accent); border-radius: 2px; }

  .psd-hero-title {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(5rem, 14vw, 10rem);
    line-height: 0.85; letter-spacing: 0.02em; color: #fff; margin: 0 0 1.5rem;
  }
  .psd-hero-title .psd-accent {
    display: block; -webkit-text-stroke: 2px var(--psd-accent); color: transparent;
    text-shadow: 0 0 80px var(--psd-glow);
  }
  .psd-hero-sub { font-size: 1.05rem; line-height: 1.75; color: rgba(255,255,255,0.75); max-width: 520px; margin-bottom: 2rem; }
  .psd-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--psd-accent); color: #fff; padding: 0.75rem 1.75rem; border-radius: 6px;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
    box-shadow: 0 0 24px rgba(232,53,122,0.4), 0 4px 12px rgba(0,0,0,0.3);
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(232,53,122,0.6), 0 8px 24px rgba(0,0,0,0.4); }
  .btn-primary:focus-visible { outline: 2px solid var(--psd-accent); outline-offset: 3px; }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: rgba(255,255,255,0.7); padding: 0.75rem 1.75rem;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 6px;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.5); transform: translateY(-2px); }
  .btn-ghost:focus-visible { outline: 2px solid rgba(255,255,255,0.5); outline-offset: 3px; }

  /* ── What's Included ── */
  .psd-what { background: #0e0f14; padding: 7rem 2rem; }
  .psd-what-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .psd-what-text h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; margin-bottom: 1.5rem; }
  .psd-what-text p { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.7); margin-bottom: 1rem; }

  .psd-feature-list { list-style: none; padding: 0; margin: 1.5rem 0 0; display: flex; flex-direction: column; gap: 1.1rem; }
  .psd-feature-list li { display: flex; align-items: flex-start; gap: 1rem; }
  .feat-icon {
    width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;
    background: rgba(232,53,122,0.12); border: 1px solid rgba(232,53,122,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; color: var(--psd-accent); margin-top: 2px;
  }
  .psd-feature-list li div { display: flex; flex-direction: column; gap: 0.2rem; }
  .psd-feature-list li strong { font-family: 'Oswald', sans-serif; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.05em; color: #fff; }
  .psd-feature-list li span { font-size: 0.82rem; line-height: 1.5; color: rgba(255,255,255,0.55); }

  .psd-what-image {
    border-radius: 16px; overflow: hidden; position: relative; aspect-ratio: 4/3;
    will-change: transform;
  }
  .psd-includes-photo { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .psd-image-badge {
    position: absolute; bottom: 1.5rem; right: 1.5rem;
    background: var(--psd-accent); border-radius: 12px; padding: 0.75rem 1.25rem;
    display: flex; align-items: center; gap: 0.6rem;
    box-shadow: 0 8px 32px rgba(232,53,122,0.5);
  }
  .badge-star { font-size: 1.1rem; color: #fff; }
  .badge-label { font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.9); }

  /* ── Party Details ── */
  .psd-addon { background: #0e0f14; padding: 7rem 2rem; border-top: 1px solid rgba(255,255,255,0.05); }
  .psd-addon-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .psd-addon-text h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; margin-bottom: 1.25rem; }
  .psd-addon-text p { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.7); margin-bottom: 1rem; }
  .psd-addon-details { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .detail-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px; padding: 1.25rem; display: flex; gap: 1rem; align-items: flex-start;
    transition: border-color 0.2s ease;
  }
  .detail-card:hover { border-color: rgba(232,53,122,0.25); }
  .detail-card i { font-size: 1.1rem; color: var(--psd-accent); flex-shrink: 0; margin-top: 2px; }
  .detail-card div { display: flex; flex-direction: column; gap: 0.25rem; }
  .detail-card strong { font-family: 'Oswald', sans-serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }
  .detail-card span { font-size: 0.85rem; color: rgba(255,255,255,0.6); }

  /* ── More Experiences ── */
  .psd-more { background: #14161e; padding: 7rem 2rem; border-top: 1px solid rgba(255,255,255,0.05); }
  .psd-more-inner { max-width: 1280px; margin: 0 auto; }
  .psd-more-inner h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; }
  .psd-more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .more-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px; padding: 1.75rem; display: flex; align-items: flex-start; gap: 1.25rem;
    text-decoration: none; color: inherit; will-change: transform;
    transition: border-color 0.2s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1), background 0.2s ease;
  }
  .more-card:hover { border-color: rgba(232,53,122,0.3); background: rgba(232,53,122,0.05); transform: translateY(-3px); }
  .more-card:focus-visible { outline: 2px solid var(--psd-accent); outline-offset: 3px; }
  .more-card-icon {
    width: 44px; height: 44px; border-radius: 10px;
    background: rgba(232,53,122,0.12); border: 1px solid rgba(232,53,122,0.2);
    display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: var(--psd-accent); flex-shrink: 0;
  }
  .more-card-content { flex: 1; }
  .more-card-content h3 { font-family: 'Oswald', sans-serif; font-size: 1rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .more-card-content p { font-size: 0.82rem; line-height: 1.6; color: rgba(255,255,255,0.55); }
  .more-card-arrow { font-size: 1.2rem; color: rgba(255,255,255,0.2); flex-shrink: 0; transition: color 0.2s ease, transform 0.2s ease; }
  .more-card:hover .more-card-arrow { color: var(--psd-accent); transform: translateX(4px); }

  /* ── CTA ── */
  .psd-cta { background: #0e0f14; padding: 8rem 2rem; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }
  .psd-cta-content { max-width: 640px; margin: 0 auto; }
  .psd-cta-slogan {
    font-family: 'Oswald', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--psd-accent);
    margin-bottom: 0.75rem;
  }
  .psd-cta-content h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 7vw, 5rem); line-height: 1; margin-bottom: 1rem; }
  .psd-cta-sub { font-size: 1rem; line-height: 1.7; color: rgba(255,255,255,0.65); margin-bottom: 2rem; }
  .psd-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .psd-what-inner, .psd-addon-inner { grid-template-columns: 1fr; gap: 3rem; }
    .psd-what-image { max-width: 560px; }
  }
  @media (max-width: 768px) {
    .psd-more-grid { grid-template-columns: 1fr; }
    .psd-addon-details { grid-template-columns: 1fr; }
  }
</style>
