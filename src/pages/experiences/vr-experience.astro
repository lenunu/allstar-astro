---
import Page from '../../layouts/Page.astro';
---

<Page
  title="VR Experience — Virtual Reality Party | All Star Party World"
  description="Strap on a VR headset and step into another world at All Star Party World. Racing, adventures, and immersive games for all ages. Available as a party add-on in Miami."
>

  <!-- Hero -->
  <section class="vr-hero" aria-label="VR Experience hero">
    <div class="vr-hero-bg" aria-hidden="true">
      <div class="vr-hero-fallback" aria-hidden="true"></div>
      <div class="vr-hero-overlay"></div>
    </div>
    <div class="vr-hero-content">
      <div class="vr-eyebrow">Signature Experience</div>
      <h1 class="vr-hero-title">VR<br /><span class="vr-accent">Experience</span></h1>
      <p class="vr-hero-sub">Strap on a headset and step into another world. Racing, adventures, and immersive games — no experience needed, just a sense of wonder.</p>
      <div class="vr-hero-actions">
        <a href="/book" class="btn-primary">Add to Your Party</a>
        <a href="#what-it-is" class="btn-ghost">Learn More</a>
      </div>
    </div>
  </section>

  <!-- What Is It -->
  <section class="vr-what" id="what-it-is" aria-label="About the VR Experience">
    <div class="vr-what-inner">
      <div class="vr-what-image vr-placeholder" role="img" aria-label="VR Experience photo">
        <div class="placeholder-content" aria-hidden="true">
          <i class="fas fa-vr-cardboard"></i>
          <span>Photos Coming Soon</span>
        </div>
        <div class="vr-image-badge" aria-hidden="true">
          <span class="badge-icon"><i class="fas fa-vr-cardboard" aria-hidden="true"></i></span>
          <span class="badge-label">Full VR</span>
        </div>
      </div>
      <div class="vr-what-text">
        <div class="section-eyebrow">The Experience</div>
        <h2>Step Into <span class="vr-accent">Another World</span></h2>
        <p>The VR Experience at All Star Party World brings cutting-edge virtual reality to your party. Kids and adults alike strap on headsets and enter fully immersive virtual environments — racing through tracks, exploring fantastical worlds, and competing in multiplayer VR games.</p>
        <p>No tech knowledge required. Our specialists set everything up and guide every guest through the experience.</p>
        <ul class="vr-feature-list" role="list">
          <li><span class="check-icon" aria-hidden="true">✦</span> Latest VR headset hardware</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Multiple game library</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Racing, adventure, and party games</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> All Star specialist on deck</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> All ages welcome</li>
          <li><span class="check-icon" aria-hidden="true">✦</span> Sanitized headsets between guests</li>
        </ul>
        <a href="/book" class="btn-primary" style="margin-top:1.5rem;display:inline-flex;">Book This Experience</a>
      </div>
    </div>
  </section>

  <!-- Add-On Banner -->
  <section class="vr-addon" aria-label="Add VR Experience to your party">
    <div class="vr-addon-inner">
      <div class="vr-addon-text">
        <div class="section-eyebrow">Party Add-On</div>
        <h2>Add It to Any Party Package</h2>
        <p>The VR Experience is available as a premium add-on to any All Star Party World package. Set up as a station guests can rotate through during your event — no downtime, no waiting.</p>
        <a href="/book" class="btn-primary">Get a Quote</a>
      </div>
      <div class="vr-addon-details" role="list">
        <div class="detail-card" role="listitem">
          <i class="fas fa-clock" aria-hidden="true"></i>
          <div><strong>Duration</strong><span>~10 min per guest</span></div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-users" aria-hidden="true"></i>
          <div><strong>Setup</strong><span>Rotating station</span></div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-child" aria-hidden="true"></i>
          <div><strong>Age Range</strong><span>All ages welcome</span></div>
        </div>
        <div class="detail-card" role="listitem">
          <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
          <div><strong>Location</strong><span>Inside All Star Party World</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- More Experiences -->
  <section class="vr-more" aria-label="More signature experiences">
    <div class="vr-more-inner">
      <div class="section-eyebrow" style="text-align:center;">More Experiences</div>
      <h2 style="text-align:center;margin-bottom:2.5rem;">Keep the <span class="vr-accent">Fun Going</span></h2>
      <div class="vr-more-grid">
        <a href="/experiences/paint-me-one" class="more-card">
          <div class="more-card-icon"><i class="fas fa-paint-brush"></i></div>
          <div class="more-card-content"><h3>Paint Me One</h3><p>Blacklight neon art studio. Kids paint glowing canvases they take home.</p></div>
          <span class="more-card-arrow">→</span>
        </a>
        <a href="/experiences/karaoke-lounge" class="more-card">
          <div class="more-card-icon"><i class="fas fa-microphone"></i></div>
          <div class="more-card-content"><h3>Karaoke Lounge</h3><p>Professional mics and stage lighting. Every guest gets their pop star moment.</p></div>
          <span class="more-card-arrow">→</span>
        </a>
        <a href="/experiences/pop-star-divas" class="more-card">
          <div class="more-card-icon"><i class="fas fa-crown"></i></div>
          <div class="more-card-content"><h3>Pop Star Divas</h3><p>Glam makeup, diva costumes, and a full pop star photo shoot moment.</p></div>
          <span class="more-card-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="vr-cta" aria-label="Book the VR Experience">
    <div class="vr-cta-content">
      <h2>Ready to <span class="vr-accent">Level Up?</span></h2>
      <p>Add the VR Experience to your next party at All Star Party World. Your guests will be talking about it for weeks.</p>
      <div class="vr-cta-actions">
        <a href="/book" class="btn-primary">Book Now</a>
        <a href="tel:+17864710100" class="btn-ghost"><i class="fas fa-phone" aria-hidden="true"></i> 786-471-0100</a>
      </div>
    </div>
  </section>

</Page>

<style>
  :root { --vr-accent: #3B7DEB; --vr-glow: rgba(59,125,235,0.35); }
  .vr-accent { color: var(--vr-accent); }
  .section-eyebrow {
    font-family: 'Oswald', sans-serif; font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--vr-accent); margin-bottom: 0.75rem;
  }

  .vr-hero { position: relative; min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
  .vr-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .vr-hero-fallback {
    width: 100%; height: 100%;
    background: radial-gradient(ellipse at 70% 40%, rgba(59,125,235,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 30% 80%, rgba(127,179,255,0.12) 0%, transparent 50%),
                #080910;
  }
  .vr-hero-overlay { position: absolute; inset: 0; background: rgba(8,9,16,0.5); }
  .vr-hero-content { position: relative; z-index: 1; max-width: 680px; padding: 8rem clamp(2rem, 8vw, 7rem) 6rem; }
  .vr-eyebrow {
    font-family: 'Oswald', sans-serif; font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--vr-accent);
    margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;
  }
  .vr-eyebrow::before { content: ''; display: block; width: 32px; height: 2px; background: var(--vr-accent); border-radius: 2px; }
  .vr-hero-title {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(6rem, 18vw, 13rem);
    line-height: 0.85; letter-spacing: 0.02em; color: #fff; margin: 0 0 1.5rem;
  }
  .vr-hero-title .vr-accent {
    display: block; -webkit-text-stroke: 2px var(--vr-accent); color: transparent;
    text-shadow: 0 0 80px var(--vr-glow); font-size: clamp(3rem, 10vw, 7rem);
  }
  .vr-hero-sub { font-size: 1.05rem; line-height: 1.75; color: rgba(255,255,255,0.75); max-width: 520px; margin-bottom: 2rem; }
  .vr-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--vr-accent); color: #fff; padding: 0.75rem 1.75rem; border-radius: 6px;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
    box-shadow: 0 0 24px rgba(59,125,235,0.4), 0 4px 12px rgba(0,0,0,0.3);
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(59,125,235,0.6), 0 8px 24px rgba(0,0,0,0.4); }
  .btn-primary:focus-visible { outline: 2px solid var(--vr-accent); outline-offset: 3px; }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: rgba(255,255,255,0.7); padding: 0.75rem 1.75rem;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 6px;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.5); transform: translateY(-2px); }
  .btn-ghost:focus-visible { outline: 2px solid rgba(255,255,255,0.5); outline-offset: 3px; }

  .vr-what { background: #0e0f14; padding: 7rem 2rem; }
  .vr-what-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .vr-what-image {
    border-radius: 16px; overflow: hidden; position: relative; aspect-ratio: 3/4;
  }
  .vr-placeholder {
    background: radial-gradient(ellipse at center, rgba(59,125,235,0.2) 0%, rgba(8,9,16,0.8) 70%), #14161e;
    border: 1px solid rgba(59,125,235,0.15);
    display: flex; align-items: center; justify-content: center;
  }
  .placeholder-content { display: flex; flex-direction: column; align-items: center; gap: 1rem; color: rgba(255,255,255,0.3); }
  .placeholder-content i { font-size: 3rem; color: rgba(59,125,235,0.3); }
  .placeholder-content span { font-family: 'Oswald', sans-serif; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; }
  .vr-image-badge {
    position: absolute; bottom: 1.5rem; left: 1.5rem;
    background: var(--vr-accent); border-radius: 12px; padding: 0.75rem 1.25rem;
    display: flex; align-items: center; gap: 0.6rem;
    box-shadow: 0 8px 32px rgba(59,125,235,0.5);
  }
  .badge-icon { font-size: 1.2rem; color: #fff; }
  .badge-label { font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.9); }

  .vr-what-text h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; margin-bottom: 1.5rem; }
  .vr-what-text p { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.7); margin-bottom: 1rem; }
  .vr-feature-list { list-style: none; padding: 0; margin: 1.5rem 0 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .vr-feature-list li { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; color: rgba(255,255,255,0.8); }
  .check-icon { color: var(--vr-accent); font-size: 0.65rem; flex-shrink: 0; }

  .vr-addon { background: #14161e; padding: 7rem 2rem; border-top: 1px solid rgba(255,255,255,0.05); }
  .vr-addon-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .vr-addon-text h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; margin-bottom: 1.25rem; }
  .vr-addon-text p { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.7); margin-bottom: 1rem; }
  .vr-addon-details { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .detail-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px; padding: 1.25rem; display: flex; gap: 1rem; align-items: flex-start; transition: border-color 0.2s ease;
  }
  .detail-card:hover { border-color: rgba(59,125,235,0.25); }
  .detail-card i { font-size: 1.1rem; color: var(--vr-accent); flex-shrink: 0; margin-top: 2px; }
  .detail-card div { display: flex; flex-direction: column; gap: 0.25rem; }
  .detail-card strong { font-family: 'Oswald', sans-serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }
  .detail-card span { font-size: 0.85rem; color: rgba(255,255,255,0.6); }

  .vr-more { background: #0e0f14; padding: 7rem 2rem; border-top: 1px solid rgba(255,255,255,0.05); }
  .vr-more-inner { max-width: 1280px; margin: 0 auto; }
  .vr-more-inner h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; }
  .vr-more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .more-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px; padding: 1.75rem; display: flex; align-items: flex-start; gap: 1.25rem;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1), background 0.2s ease;
  }
  .more-card:hover { border-color: rgba(59,125,235,0.3); background: rgba(59,125,235,0.05); transform: translateY(-3px); }
  .more-card:focus-visible { outline: 2px solid var(--vr-accent); outline-offset: 3px; }
  .more-card-icon {
    width: 44px; height: 44px; border-radius: 10px;
    background: rgba(59,125,235,0.12); border: 1px solid rgba(59,125,235,0.2);
    display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: var(--vr-accent); flex-shrink: 0;
  }
  .more-card-content { flex: 1; }
  .more-card-content h3 { font-family: 'Oswald', sans-serif; font-size: 1rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .more-card-content p { font-size: 0.82rem; line-height: 1.6; color: rgba(255,255,255,0.55); }
  .more-card-arrow { font-size: 1.2rem; color: rgba(255,255,255,0.2); flex-shrink: 0; transition: color 0.2s ease, transform 0.2s ease; }
  .more-card:hover .more-card-arrow { color: var(--vr-accent); transform: translateX(4px); }

  .vr-cta { background: #14161e; padding: 8rem 2rem; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }
  .vr-cta-content { max-width: 600px; margin: 0 auto; }
  .vr-cta-content h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 7vw, 5rem); line-height: 1; margin-bottom: 1rem; }
  .vr-cta-content p { font-size: 1rem; line-height: 1.7; color: rgba(255,255,255,0.65); margin-bottom: 2rem; }
  .vr-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 1024px) {
    .vr-what-inner, .vr-addon-inner { grid-template-columns: 1fr; gap: 3rem; }
    .vr-what-image { max-width: 480px; }
  }
  @media (max-width: 768px) {
    .vr-more-grid { grid-template-columns: 1fr; }
    .vr-addon-details { grid-template-columns: 1fr; }
  }
</style>
