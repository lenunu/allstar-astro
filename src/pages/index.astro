    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 100% at 50% 50%, rgba(59,125,235,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 0.95;
    margin-bottom: 1rem;
  }
  .cta-headline .blue { color: #3B7DEB; }
  .cta-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.65;
    margin-bottom: 2rem;
  }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* ── ANIMATIONS ── */
  /* hero intro — elements start hidden, JS adds .is-visible */
  .hi-0, .hi-1, .hi-2, .hi-3, .hi-4 {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1);
  }
  .hi-1 { transform: translateY(70px); }
  .hi-4 { transform: translateY(40px) scale(0.96); transition-property: opacity, transform; }

  .hi-0.is-visible,
  .hi-1.is-visible,
  .hi-2.is-visible,
  .hi-3.is-visible,
  .hi-4.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .hi-0, .hi-1, .hi-2, .hi-3, .hi-4 { opacity: 1; transform: none; transition: none; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .venues-grid { grid-template-columns: 1fr; }
    .events-grid { grid-template-columns: 1fr 1fr; }
    .book-grid { grid-template-columns: 1fr; }
    .stats-inner { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: 1fr; }
    .testimonial-card.featured { grid-column: span 1; }
    .catering-grid { grid-template-columns: 1fr; }
    .experiences-grid { grid-template-columns: 1fr 1fr; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item.span2 { grid-column: span 1; }
    .gallery-item.tall { grid-row: span 1; }
  }

  @media (max-width: 768px) {
    .hero-venues { grid-template-columns: 1fr; }
    .events-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .form-group.full { grid-column: span 1; }
    .experiences-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  // Stats strip — trigger when scrolled into view
  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
        statsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.4 });
  document.querySelectorAll('.stat-item').forEach(el => statsObserver.observe(el));

  // Hero intro sequence
  const delays = [0, 300, 600, 850, 1100];
  ['hi-0','hi-1','hi-2','hi-3','hi-4'].forEach((cls, i) => {
    const el = document.querySelector(`.${cls}`) as HTMLElement | null;
    if (el) setTimeout(() => el.classList.add('is-visible'), delays[i]);
  });

  function toggleFaq(btn: HTMLElement) {
    const item = btn.closest('.faq-item') as HTMLElement;
    const isOpen = item.classList.contains('open');
    // Close all
    document.querySelectorAll('.faq-item.open').forEach((el) => {
      el.classList.remove('open');
      const q = el.querySelector('.faq-question') as HTMLElement;
      if (q) q.setAttribute('aria-expanded', 'false');
    });
    // Open clicked if it was closed
    if (!isOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }

  document.querySelectorAll('.faq-question').forEach((btn) => {
    btn.addEventListener('click', () => toggleFaq(btn as HTMLElement));
  });
</script>
