---
import Page from '../layouts/Page.astro';
---

<Page
  title="All Star Party World & The 305 Club — Two Venues. One Destination."
  description="Two premier party venues in Miami. All Star Party World for kids ages 4–12. The 305 Club for teens & adults. TWO VENUES / One Destination. Multiple Experiences."
>

  <!-- ── HERO ── -->
  <section class="hero" aria-label="Hero — Two Venues, One Destination">
    <div class="hero-video-bg" aria-hidden="true">
      <video autoplay muted loop playsinline preload="auto">
        <source src="/305-event-photos/hero-bkg-305-optimized.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero-video-overlay" aria-hidden="true"></div>

    <div class="hero-split-bg" aria-hidden="true">
      <div class="hero-split-left">
        <img src="/allstar-event-photos/bounce-hero.webp" alt="" />
      </div>
      <div class="hero-split-right">
        <img src="/305-event-photos/305 dance floor 2.jpg" alt="" />
      </div>
    </div>
    <div class="hero-bottom-fade" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="hero-text">
        <div class="hero-eyebrow hi-0">Miami's Premier Party Destinations</div>

        <h1 class="hero-headline hi-1">
          <span class="line-yellow">TWO<br>VENUES.</span><br>
          <span style="color:#fff;">ONE</span><br>
          <span class="line-blue">DESTINATION.</span>
        </h1>

        <p class="hero-tagline hi-2">
          <span>Multiple Experiences.</span> Every Celebration Covered.
        </p>

        <div class="hero-actions hi-3">
          <a href="/book" class="btn-primary">Book Your Event →</a>
          <a href="#venues" class="btn-outline">Explore Venues</a>
        </div>

        <div class="hero-venues hi-4">
          <a href="/all-star-party-world" class="hero-venue-card hvc-allstar">
            <img src="/brand_assets/all-star-logo.png" alt="All Star Party World logo" class="hvc-logo" />
            <div class="hvc-body">
              <div class="hvc-tag">Kids · Ages 4–12</div>
              <div class="hvc-name">All Star Party World</div>
              <div class="hvc-desc">6,000 sq ft · Bounce houses, laser tag, Nerf wars & more.</div>
            </div>
            <span class="hvc-number" aria-hidden="true">01</span>
          </a>
          <a href="/305-club" class="hero-venue-card hvc-305">
            <img src="/brand_assets/305-logo.png" alt="The 305 Club logo" class="hvc-logo" />
            <div class="hvc-body">
              <div class="hvc-tag">Teens &amp; Adults</div>
              <div class="hvc-name">The 305 Club</div>
              <div class="hvc-desc">10,000 sq ft · DJ, VIP, quinces, sweet 16s, corporate events.</div>
            </div>
            <span class="hvc-number" aria-hidden="true">02</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── VENUES ── -->
  <section id="venues" class="venues-section" aria-label="Our Venues">
    <div class="venues-grid">

      <div id="allstar" class="venue-panel vp-allstar">
        <div class="venue-panel-img" aria-hidden="true">
          <img src="/allstar-event-photos/bounce-hero.webp" alt="" />
        </div>
        <div class="venue-panel-overlay" aria-hidden="true"></div>
        <div class="venue-panel-color" aria-hidden="true"></div>
        <div class="venue-panel-content">
          <span class="vp-badge">01 · Kids · Ages 4–12</span>
          <h2 class="vp-title">All Star<br>Party World</h2>
          <p class="vp-desc">Miami's ultimate indoor party playground. 6,000 sq ft of pure fun — the perfect venue for birthdays, school events, and group celebrations where every kid becomes the all-star.</p>
          <div class="vp-features">
            <span class="vp-feature-tag"><i class="fas fa-ring" aria-hidden="true"></i>Bounce Houses</span>
            <span class="vp-feature-tag"><i class="fas fa-crosshairs" aria-hidden="true"></i>Laser Tag</span>
            <span class="vp-feature-tag"><i class="fas fa-gun" aria-hidden="true"></i>Nerf Wars</span>
            <span class="vp-feature-tag"><i class="fas fa-lightbulb" aria-hidden="true"></i>Blacklight Glow Room</span>
            <span class="vp-feature-tag"><i class="fas fa-trophy" aria-hidden="true"></i>Sports Activities</span>
            <span class="vp-feature-tag"><i class="fas fa-cake-candles" aria-hidden="true"></i>Party Packages</span>
          </div>
          <a href="/all-star-party-world" class="btn-venue-allstar">Plan Your Party →</a>
        </div>
      </div>

      <div id="club305" class="venue-panel vp-305">
        <div class="venue-panel-img" aria-hidden="true">
          <img src="/305-event-photos/305-hero-dance.webp" alt="" />
        </div>
        <div class="venue-panel-overlay" aria-hidden="true"></div>
        <div class="venue-panel-color" aria-hidden="true"></div>
        <div class="venue-panel-content">
          <span class="vp-badge">02 · Teens &amp; Adults</span>
          <h2 class="vp-title">The<br>305 Club</h2>
          <p class="vp-desc">Miami's premier nightclub-style event venue. 10,000 sq ft of elevated celebration — where quinces, sweet 16s, corporate events, and private parties become unforgettable experiences.</p>
          <div class="vp-features">
            <span class="vp-feature-tag"><i class="fas fa-music" aria-hidden="true"></i>Professional DJ</span>
            <span class="vp-feature-tag"><i class="fas fa-spray-can" aria-hidden="true"></i>Graffiti Wall</span>
            <span class="vp-feature-tag"><i class="fas fa-gem" aria-hidden="true"></i>VIP Experience</span>
            <span class="vp-feature-tag"><i class="fas fa-sparkles" aria-hidden="true"></i>Quinceañeras</span>
            <span class="vp-feature-tag"><i class="fas fa-party-horn" aria-hidden="true"></i>Sweet 16s</span>
            <span class="vp-feature-tag"><i class="fas fa-briefcase" aria-hidden="true"></i>Corporate Events</span>
          </div>
          <a href="/305-club" class="btn-venue-305">Plan Your Event →</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ── STATS STRIP ── -->
  <div class="stats-strip" aria-label="By the numbers">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-number">16K+</div>
        <div class="stat-label">Sq Ft Combined</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">500+</div>
        <div class="stat-label">Events Per Year</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">2</div>
        <div class="stat-label">Unique Venues</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">10K+</div>
        <div class="stat-label">Memories Made</div>
      </div>
    </div>
  </div>

  <!-- ── MARQUEE STRIP ── -->
  <div class="marquee-strip" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-word">BIRTHDAY PARTIES</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">QUINCEAÑERAS</span>
      <span class="marquee-dot blue">✦</span>
      <span class="marquee-word">SWEET 16S</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">CORPORATE EVENTS</span>
      <span class="marquee-dot blue">✦</span>
      <span class="marquee-word">LASER TAG</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">VIP EXPERIENCES</span>
      <span class="marquee-dot blue">✦</span>
      <span class="marquee-word">PRIVATE PARTIES</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">BOUNCE HOUSES</span>
      <span class="marquee-dot blue">✦</span>
      <!-- duplicate for seamless loop -->
      <span class="marquee-word">BIRTHDAY PARTIES</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">QUINCEAÑERAS</span>
      <span class="marquee-dot blue">✦</span>
      <span class="marquee-word">SWEET 16S</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">CORPORATE EVENTS</span>
      <span class="marquee-dot blue">✦</span>
      <span class="marquee-word">LASER TAG</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">VIP EXPERIENCES</span>
      <span class="marquee-dot blue">✦</span>
      <span class="marquee-word">PRIVATE PARTIES</span>
      <span class="marquee-dot yellow">✦</span>
      <span class="marquee-word">BOUNCE HOUSES</span>
      <span class="marquee-dot blue">✦</span>
    </div>
  </div>

  <!-- ── SIGNATURE EXPERIENCES ── -->
  <section class="experiences-section" aria-label="Signature Party Experiences">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-eyebrow">Unforgettable Moments</div>
        <h2 class="section-title">Signature<br><span class="yellow">Party Experiences</span></h2>
      </div>

      <div class="experiences-grid">

        <a href="/experiences/karaoke-lounge" class="exp-card">
          <img src="/305-event-photos/karaoke.png" alt="Karaoke Lounge at The 305 Club" class="exp-img" />
          <div class="exp-overlay" style="background: linear-gradient(135deg, rgba(59,125,235,0.75), rgba(0,0,0,0.85));"></div>
          <div class="exp-content">
            <div><span class="exp-badge blue">The 305 Club</span></div>
            <div>
              <h3 class="exp-title">Karaoke Lounge</h3>
              <p class="exp-desc">Turn up the party with pro sound, massive video wall, interactive staff, and your own photo booth experience.</p>
            </div>
          </div>
        </a>

        <a href="/experiences/paint-me-one" class="exp-card">
          <img src="/305-event-photos/paintmeone-bkg.jpeg" alt="Paint Me One creative art party" class="exp-img" />
          <div class="exp-overlay" style="background: linear-gradient(135deg, rgba(34,211,102,0.75), rgba(0,0,0,0.85));"></div>
          <div class="exp-content">
            <div><span class="exp-badge green">Creative Art</span></div>
            <div>
              <h3 class="exp-title">Paint Me One</h3>
              <p class="exp-desc">Personalized paint parties where everyone leaves with their own one-of-a-kind masterpiece.</p>
            </div>
          </div>
        </a>

        <a href="/experiences/pop-star-divas" class="exp-card">
          <img src="/305-event-photos/divas.jpg" alt="Pop Star Divas glam experience" class="exp-img" />
          <div class="exp-overlay" style="background: linear-gradient(135deg, rgba(232,53,122,0.75), rgba(0,0,0,0.85));"></div>
          <div class="exp-content">
            <div><span class="exp-badge pink">Glam Experience</span></div>
            <div>
              <h3 class="exp-title">Pop Star Divas</h3>
              <p class="exp-desc">The ultimate glam experience where every child steps into the spotlight feeling like a total superstar.</p>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ── EVENTS ── -->
  <section id="events" class="events-section" aria-label="Events We Host">
    <div class="section-inner">
      <div class="section-eyebrow">What We Host</div>
      <div class="events-header">
        <h2 class="section-title">Every Occasion,<br>Covered.</h2>
        <a href="/book" class="btn-primary">View All Events →</a>
      </div>

      <div class="events-grid">

        <div class="event-card">
          <div class="event-card-img" style="background-image: url('/allstar-event-photos/inflatable-bounce-house-and-obstacle-course.jpg'); background-size: cover; background-position: center;"></div>
          <div class="event-card-body">
            <div class="event-venue-tag evt-allstar">All Star Party World</div>
            <div class="event-card-title">Kids Birthday Parties</div>
            <div class="event-card-desc">Full-venue takeovers with bounce houses, games, decorations, and catering. Packages for groups of 10–80 kids.</div>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 quinces.jpg" alt="Quinceañera at The 305 Club" />
          </div>
          <div class="event-card-body">
            <div class="event-venue-tag evt-305">The 305 Club</div>
            <div class="event-card-title">Quinceañeras</div>
            <div class="event-card-desc">Celebrate her quinceañera in style. Full DJ production, custom lighting, dance floor, and VIP packages.</div>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 15 b-day.jpg" alt="15th Birthday party" />
          </div>
          <div class="event-card-body">
            <div class="event-venue-tag evt-305">The 305 Club</div>
            <div class="event-card-title">Sweet 16s</div>
            <div class="event-card-desc">Make it legendary. Professional DJ, graffiti wall, photo ops, VIP treatment, and unforgettable energy.</div>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 dance floor 2.jpg" alt="Corporate event dance floor" />
          </div>
          <div class="event-card-body">
            <div class="event-venue-tag evt-305">The 305 Club</div>
            <div class="event-card-title">Corporate Events</div>
            <div class="event-card-desc">Team-building, company parties, and client events done right. Premium AV, catering, and full-service coordination.</div>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img" style="background-image: url('/allstar-event-photos/kids-parachute-game-activity-party.jpg'); background-size: cover; background-position: center;"></div>
          <div class="event-card-body">
            <div class="event-venue-tag evt-allstar">All Star Party World</div>
            <div class="event-card-title">School &amp; Group Events</div>
            <div class="event-card-desc">Field trips, after-school celebrations, and group play sessions for schools and youth organizations.</div>
          </div>
        </div>

        <div class="event-card">
          <div class="event-card-img">
            <img src="/305-event-photos/305 58th b-day.jpg" alt="Private birthday party" />
          </div>
          <div class="event-card-body">
            <div class="event-venue-tag evt-305">The 305 Club</div>
            <div class="event-card-title">Private Parties</div>
            <div class="event-card-desc">Graduations, mitzvahs, anniversaries, and beyond. Both venues available for exclusive buyouts.</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- ── GALLERY ── -->
  <section id="gallery" class="gallery-section" aria-label="Event Gallery">
    <div class="gallery-glow" aria-hidden="true"></div>
    <div class="section-inner">
      <div class="section-eyebrow">The 305 Club — Real Events</div>
      <div class="gallery-header">
        <h2 class="section-title">See It<br><span class="blue">In Action.</span></h2>
        <a href="/book" class="btn-primary">Book Your Event →</a>
      </div>

      <div class="gallery-grid" role="list">

        <div class="gallery-item span2 tall" role="listitem">
          <img src="/305-event-photos/305 dance floor 2.jpg" alt="The 305 Club dance floor" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">The 305 Club</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 quinces.jpg" alt="Quinceañera celebration" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Quinceañera</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 360 photo booth.jpg" alt="360 degree photo booth" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">360° Photo Booth</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 15 b-day.jpg" alt="15th birthday party" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">15th Birthday</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 58th b-day.jpg" alt="Birthday balloon arch" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Birthday Balloon Arch</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 13th b-day 2.jpg" alt="13th birthday celebration" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">13th Birthday</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 event 13th b-day.jpg" alt="Dance floor vibes" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Dance Floor Vibes</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 holloween 3.jpg" alt="Halloween themed event" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Halloween Setup</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 event food.jpg" alt="Event catering and grazing" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Catering &amp; Grazing</div>
        </div>

        <div class="gallery-item span2" role="listitem">
          <img src="/305-event-photos/305 event halloween.jpg" alt="Wonderland themed event setup" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Themed Events — Wonderland</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 event halloween 2.jpg" alt="Themed event decor" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">Themed Decor</div>
        </div>

        <div class="gallery-item" role="listitem">
          <img src="/305-event-photos/305 10th b-day.jpg" alt="Neon 10th birthday party" loading="lazy" />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <div class="gallery-label">10th Birthday Neon</div>
        </div>

      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/gallery" class="btn-outline">View Full Gallery →</a>
      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- ── TESTIMONIALS ── -->
  <section class="testimonials-section" aria-label="Customer Reviews">
    <div class="testimonials-glow1" aria-hidden="true"></div>
    <div class="testimonials-glow2" aria-hidden="true"></div>
    <div class="section-inner">

      <div class="testimonials-header">
        <div>
          <div class="section-eyebrow">Google Reviews</div>
          <h2 class="section-title" style="margin-bottom:0.5rem;">What Families<br><span class="yellow">Are Saying.</span></h2>
        </div>
        <div class="rating-summary">
          <div>
            <div class="stars">★★★★★</div>
            <div class="review-count">132 Google Reviews</div>
          </div>
        </div>
      </div>

      <div class="testimonials-grid">

        <div class="testimonial-card">
          <div class="stars-sm">★★★★★</div>
          <p class="testimonial-text">"Great party, so much to do for the kids!! The parents can relax while the kids have a blast. The staff was amazing, went above and beyond for everything."</p>
          <div class="testimonial-footer">
            <div class="avatar" style="background: linear-gradient(135deg,#e8a,#a8e);">S</div>
            <div>
              <div class="reviewer-name">Stephanie Fedak</div>
              <div class="reviewer-meta">1 month ago</div>
            </div>
            <img src="https://www.google.com/favicon.ico" alt="Google" class="google-icon" />
          </div>
        </div>

        <div class="testimonial-card">
          <div class="stars-sm">★★★★★</div>
          <p class="testimonial-text">"Awesome — the kids had a lot of fun. The DJ was great playing all different music and even taught them dance moves. Very clean and organized. The staff always helpful. Will recommend this place for any party."</p>
          <div class="testimonial-footer">
            <div class="avatar" style="background: linear-gradient(135deg,#8ae,#ea8);">M</div>
            <div>
              <div class="reviewer-name">Miraldy Morales</div>
              <div class="reviewer-meta">Local Guide · 4 months ago</div>
            </div>
            <img src="https://www.google.com/favicon.ico" alt="Google" class="google-icon" />
          </div>
        </div>

        <div class="testimonial-card">
          <div class="stars-sm">★★★★★</div>
          <p class="testimonial-text">"The staff made it easy to relax and enjoy the party. The guests had a great time, both young and old. Kids had choices — bounce houses, floor games, or staff-led activities. Adults could enjoy it too. Highly recommend!"</p>
          <div class="testimonial-footer">
            <div class="avatar" style="background: linear-gradient(135deg,#f85,#85f);">L</div>
            <div>
              <div class="reviewer-name">Laura Cominsky</div>
              <div class="reviewer-meta">3 weeks ago</div>
            </div>
            <img src="https://www.google.com/favicon.ico" alt="Google" class="google-icon" />
          </div>
        </div>

        <div class="testimonial-card">
          <div class="stars-sm">★★★★★</div>
          <p class="testimonial-text">"It was truly a wonderful experience! Everyone was so helpful from the minute I got there to the end of the party. Laura and her crew made everything so easy. The kids and adults all had a blast! Michi was so great with all the planning."</p>
          <div class="testimonial-footer">
            <div class="avatar" style="background: linear-gradient(135deg,#59d,#d95);">L</div>
            <div>
              <div class="reviewer-name">Laura</div>
              <div class="reviewer-meta">4 months ago</div>
            </div>
            <img src="https://www.google.com/favicon.ico" alt="Google" class="google-icon" />
          </div>
        </div>

        <div class="testimonial-card featured">
          <div class="featured-header">
            <span class="stars-sm">★★★★★</span>
            <span class="featured-label">Featured Review</span>
          </div>
          <p class="testimonial-text" style="font-size:1rem;">"We had our daughter's birthday party here and it was AMAZING. Every single staff member was attentive, kind, and made sure all the kids were having the best time. The venue is clean, well-organized and the kids had so many activities to choose from. We will definitely be coming back!"</p>
          <div class="testimonial-footer" style="border-top-color: rgba(245,197,24,0.1);">
            <div class="avatar" style="width:42px;height:42px;background: linear-gradient(135deg, #F5C518, #FF6B2B); color:#000;">A</div>
            <div>
              <div class="reviewer-name">All Star Party World Parent</div>
              <div class="reviewer-meta">Verified Google Review</div>
            </div>
          </div>
          <a href="https://g.co/kgs/allstarpartyworld" target="_blank" rel="noopener noreferrer" class="read-reviews-btn">Read All 132 Reviews →</a>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- ── BOOKING FORM ── -->
  <section id="book" class="book-section" aria-label="Book Your Event">
    <div class="book-cta-inner">
      <p class="section-eyebrow">Get Started</p>
      <h2 class="book-cta-title">Plan Your <span class="blue">Perfect</span> Event.</h2>
      <p class="book-cta-sub">Tell us about your celebration and we'll reach out with availability, pricing, and everything you need to make it unforgettable.</p>
