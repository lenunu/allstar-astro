    background: linear-gradient(90deg, rgba(59,125,235,1), rgba(59,90,200,1));
  }

  .stats-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    opacity: 0;
  }
  .stat-item.in-view .stat-number {
    animation: statNum 0.6s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .stat-item.in-view .stat-label {
    animation: statLabel 0.5s cubic-bezier(0.22,1,0.36,1) 0.2s forwards;
  }
  .stat-item.in-view { opacity: 1; }

  .stat-item:nth-child(1).in-view .stat-number { animation-delay: 0s; }
  .stat-item:nth-child(2).in-view .stat-number { animation-delay: 0.1s; }
  .stat-item:nth-child(3).in-view .stat-number { animation-delay: 0.2s; }
  .stat-item:nth-child(4).in-view .stat-number { animation-delay: 0.3s; }
  .stat-item:nth-child(1).in-view .stat-label  { animation-delay: 0.2s; }
  .stat-item:nth-child(2).in-view .stat-label  { animation-delay: 0.3s; }
  .stat-item:nth-child(3).in-view .stat-label  { animation-delay: 0.4s; }
  .stat-item:nth-child(4).in-view .stat-label  { animation-delay: 0.5s; }

  @keyframes statNum {
    from { opacity: 0; transform: scale(1.4); filter: blur(2px); }
    to   { opacity: 1; transform: scale(1);   filter: blur(0); }
  }
  @keyframes statLabel {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 0.75; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-item { opacity: 1; }
    .stat-item .stat-number, .stat-item .stat-label { animation: none !important; opacity: 1 !important; transform: none !important; }
  }

  .stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .stat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  /* ── MARQUEE ── */
  .marquee-strip {
    background: #111218;
