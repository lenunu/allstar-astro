---
import Page from '../layouts/Page.astro';
---

<Page
  title="Contact Us — All Star Party World & The 305 Club"
  description="Get in touch with All Star Party World and The 305 Club. Located at 8770 SW 131st Street, Miami, FL 33176. Call us at 786-471-0100 or book online."
>

  <!-- ── HERO ── -->
  <section class="c-hero">
    <div class="c-wrap">
      <p class="section-eyebrow hi-0">Get In Touch</p>
      <h1 class="c-hero-title hi-1">Let's Make Your<br /><span class="c-blue">Party Happen.</span></h1>
      <p class="c-hero-sub hi-2">Two venues. One team. We're here to answer your questions and help you plan the perfect event.</p>
    </div>
  </section>

  <!-- ── INFO + MAP ── -->
  <section class="c-info-map">
    <div class="c-wrap">
      <div class="c-grid">

        <!-- Contact Cards -->
        <div class="c-cards">
          <div class="c-card">
            <div class="c-icon"><i class="fas fa-phone" aria-hidden="true"></i></div>
            <div>
              <div class="c-label">Phone</div>
              <a href="tel:+17864710100" class="c-val">(786) 471-0100</a>
              <div class="c-sub">Mon–Sun · 10am–8pm</div>
            </div>
          </div>

          <div class="c-card">
            <div class="c-icon"><i class="fas fa-location-dot" aria-hidden="true"></i></div>
            <div>
              <div class="c-label">Address</div>
              <div class="c-val">8770 SW 131st Street</div>
              <div class="c-sub">Miami, Florida 33176<br />Next to The Falls Shopping Center</div>
            </div>
          </div>

          <div class="c-card">
            <div class="c-icon"><i class="fas fa-calendar-check" aria-hidden="true"></i></div>
            <div>
              <div class="c-label">Book an Event</div>
              <div class="c-val">Ready to reserve your date?</div>
              <a href="/book" class="btn-primary c-book-btn">Book Now →</a>
            </div>
          </div>

          <div class="c-card">
            <div class="c-icon c-icon-yellow"><i class="fab fa-instagram" aria-hidden="true"></i></div>
            <div>
              <div class="c-label">Follow Us</div>
              <div class="c-val">@allstarpartyworld</div>
              <div class="c-socials">
                <a href="https://www.instagram.com/allstarpartyworld/" target="_blank" rel="noopener noreferrer"><i class="fab fa-instagram" aria-hidden="true"></i> Instagram</a>
                <a href="https://www.facebook.com/AllStarPartyMiami/" target="_blank" rel="noopener noreferrer"><i class="fab fa-facebook" aria-hidden="true"></i> Facebook</a>
                <a href="https://www.youtube.com/@AllStarPartyWorld" target="_blank" rel="noopener noreferrer"><i class="fab fa-youtube" aria-hidden="true"></i> YouTube</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="c-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3594.4!2d-80.3359375!3d25.648323!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d9c6933ae779e1%3A0xbc526a88589cc414!2sAll+Star+Party+World!5e0!3m2!1sen!2sus!4v1"
            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="All Star Party World & The 305 Club location"
            aria-label="Google Maps showing All Star Party World at 8770 SW 131st Street, Miami, FL"
          ></iframe>
          <a href="https://www.google.com/maps/dir/?api=1&destination=All+Star+Party+World&destination_place_id=ChIJ4Xmno7PGwYgRFMScWIiqJrw"
            target="_blank" rel="noopener noreferrer" class="c-directions">
            <i class="fas fa-diamond-turn-right" aria-hidden="true"></i> Get Directions
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── VENUES ── -->
  <section class="c-venues">
    <div class="c-wrap">
      <div class="c-venues-grid">
        <div class="c-venue-card c-venue-allstar">
          <div class="c-venue-bar"></div>
          <div class="c-venue-body">
            <p class="section-eyebrow" style="color:#F5C518;">All Star Party World</p>
            <h3>Kids Ages 4–12</h3>
            <p>6,000 sq ft indoor playground — bounce houses, laser tag, Nerf wars, blacklight glow room, and arcade games. One party at a time, fully private.</p>
            <a href="/all-star-party-world" class="c-btn-yellow">Explore Venue →</a>
          </div>
        </div>
        <div class="c-venue-card c-venue-305">
          <div class="c-venue-bar"></div>
          <div class="c-venue-body">
            <p class="section-eyebrow" style="color:#3B7DEB;">The 305 Club</p>
            <h3>Teens &amp; Adults</h3>
            <p>10,000 sq ft nightclub-style event space — quinceañeras, sweet 16s, corporate events, and private parties with full DJ production and VIP experiences.</p>
            <a href="/305-club" class="c-btn-blue">Explore Venue →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="c-cta">
    <div class="c-cta-inner">
      <h2>Ready to Book?</h2>
      <p>Fill out our booking form and we'll get back to you within 24 hours to confirm your date.</p>
      <div class="c-cta-actions">
        <a href="/book" class="c-btn-book">Book Your Event →</a>
        <a href="tel:+17864710100" class="c-ghost">(786) 471-0100</a>
      </div>
    </div>
  </section>

</Page>

<style>
  /* ── Shared container ── */
  .c-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  .c-hero {
    background: #0e0f14;
    padding: 6rem 0 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .c-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    color: #fff;
    margin: 0.5rem 0 1rem;
  }
  .c-blue { color: #3B7DEB; }
  .c-hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    max-width: 480px;
    line-height: 1.6;
  }

  /* ── Info + Map ── */
  .c-info-map {
    background: #0e0f14;
    padding: 3rem 0 4rem;
  }
  .c-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .c-cards { display: flex; flex-direction: column; gap: 1rem; }
  .c-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #14161e;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .c-icon {
    width: 40px; height: 40px;
    border-radius: 9px;
    background: rgba(59,125,235,0.15);
    border: 1px solid rgba(59,125,235,0.25);
    display: flex; align-items: center; justify-content: center;
    color: #3B7DEB; font-size: 1rem; flex-shrink: 0;
  }
  .c-icon-yellow {
    background: rgba(245,197,24,0.12);
    border-color: rgba(245,197,24,0.25);
    color: #F5C518;
  }
  .c-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(255,255,255,0.4);
    margin-bottom: 0.2rem;
  }
  .c-val {
    font-size: 0.95rem; font-weight: 600; color: #fff;
    text-decoration: none; display: block; margin-bottom: 0.2rem;
  }
  a.c-val:hover { color: #3B7DEB; }
  .c-sub { font-size: 0.8rem; color: rgba(255,255,255,0.45); line-height: 1.5; }
  .c-book-btn { margin-top: 0.65rem; font-size: 0.85rem; padding: 0.55rem 1.2rem; }
  .c-socials { display: flex; gap: 1rem; margin-top: 0.4rem; flex-wrap: wrap; }
  .c-socials a {
    font-size: 0.8rem; color: rgba(255,255,255,0.5);
    text-decoration: none; display: flex; align-items: center; gap: 0.3rem;
    transition: color 0.2s ease;
  }
  .c-socials a:hover { color: #fff; }

  /* Map */
  .c-map {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    min-height: 440px;
    height: 100%;
  }
  .c-map iframe {
    display: block;
    width: 100%; height: 100%;
    min-height: 440px;
    filter: invert(93%) hue-rotate(180deg) saturate(0.45) brightness(0.88) contrast(1.05);
  }
  .c-directions {
    position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%);
    background: #3B7DEB; color: #fff;
    font-family: 'Oswald', sans-serif; font-size: 0.82rem;
    letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none;
    padding: 0.6rem 1.4rem; border-radius: 8px;
    display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .c-directions:hover { background: #2d6fd4; transform: translateX(-50%) translateY(-2px); }

  /* ── Venues ── */
  .c-venues {
    background: #14161e;
    padding: 4rem 0;
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .c-venues-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .c-venue-card {
    background: #1c1f2b;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px; overflow: hidden;
  }
  .c-venue-bar { height: 4px; }
  .c-venue-allstar .c-venue-bar { background: #F5C518; }
  .c-venue-305 .c-venue-bar { background: #3B7DEB; }
  .c-venue-body {
    padding: 1.75rem;
    display: flex; flex-direction: column; gap: 0.65rem;
  }
  .c-venue-body h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem; color: #fff; margin: 0;
  }
  .c-venue-body p { font-size: 0.88rem; color: rgba(255,255,255,0.6); line-height: 1.6; margin: 0; }
  .c-btn-yellow {
    display: inline-flex; align-items: center;
    background: #F5C518; color: #0e0f14;
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 0.82rem; letter-spacing: 0.06em; text-transform: uppercase;
    text-decoration: none; padding: 0.6rem 1.3rem; border-radius: 8px;
    margin-top: 0.25rem; align-self: flex-start;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .c-btn-yellow:hover { background: #e6b800; transform: translateY(-2px); }
  .c-btn-blue {
    display: inline-flex; align-items: center;
    background: #3B7DEB; color: #fff;
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 0.82rem; letter-spacing: 0.06em; text-transform: uppercase;
    text-decoration: none; padding: 0.6rem 1.3rem; border-radius: 8px;
    margin-top: 0.25rem; align-self: flex-start;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .c-btn-blue:hover { background: #2d6fd4; transform: translateY(-2px); }

  /* ── CTA ── */
  .c-cta {
    background: linear-gradient(135deg, #1c1f2b 0%, #14161e 100%);
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 5rem 2rem; text-align: center;
  }
  .c-cta-inner { max-width: 560px; margin: 0 auto; }
  .c-cta h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem); color: #fff; margin: 0 0 1rem;
  }
  .c-cta p { color: rgba(255,255,255,0.6); font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; }
  .c-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .c-btn-book {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #3B7DEB; color: #fff;
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase;
    text-decoration: none; padding: 0.85rem 2rem; border-radius: 8px;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .c-btn-book:hover { background: #2d6fd4; transform: translateY(-2px); }
  .c-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: transparent; border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.8);
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 0.9rem; letter-spacing: 0.06em; text-transform: uppercase;
    text-decoration: none; padding: 0.85rem 2rem; border-radius: 8px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .c-ghost:hover { border-color: rgba(255,255,255,0.5); color: #fff; }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .c-grid { grid-template-columns: 1fr; }
    .c-map { min-height: 360px; }
    .c-map iframe { min-height: 360px; }
    .c-venues-grid { grid-template-columns: 1fr; }
    .c-faq-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 600px) {
    .c-hero { padding: 5rem 0 2.5rem; }
    .c-cta-actions { flex-direction: column; align-items: center; }
  }
</style>

